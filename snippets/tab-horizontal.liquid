<style>
  #product-page-tabs{
    font-weight: initial
  }
  @media screen and (max-width: 1280px) {
    .product-detail-left-item,
    .product-detail-right-item {
      margin: 0px auto;
      padding: 40px 16px;
      background-color: rgb(245, 247, 252);
    }

    .product-detail-title {
      margin: 0px 0px 32px;
      font-weight: 600;
      font-size: 28px;
      line-height: 36px;
      font-family: Roobert, Arial, Helvetica, sans-serif;
      color: rgb(38, 43, 56);
      text-transform: inherit;
      text-align: center;
    }

    .product-detail-item-box {
      display: flex;
      flex-direction: column;
      max-width: 1280px;
      margin: 0px auto;
      -webkit-box-align: center;
      align-items: center;
      -webkit-box-pack: justify;
      justify-content: space-between;
    }

    .product-detail-item-box-right {
      flex-direction: column-reverse;
    }

    .product-detail-item-picture {
      background: rgb(216, 219, 230);
      max-width: 624px;
      max-height: 624px;
      width: 100%;
      aspect-ratio: 1 / 1;
      border-radius: 8px;
      overflow: hidden;
    }

    .product-detail-item-content {
      margin-top: 24px;
    }

    .product-detail-item-title {
      display: flex;
      align-items: flex-start;
      text-align: left;
      margin-bottom: 16px;
    }

    .product-detail-item-title-text {
      margin: 0px;
      font-weight: 600;
      font-size: 28px;
      line-height: 36px;
      font-family: Roobert, Arial, Helvetica, sans-serif;
      color: rgb(38, 43, 56);
    }

    .product-detail-item-description {
      margin: 0px;
      font-weight: 400;
      font-size: 16px;
      line-height: 22px;
      color: rgb(88, 98, 128);
    }
  }

  @media screen and (min-width: 1280px) {
    .product-detail-left-item {
      margin-bottom: 30px;
    }

    .product-detail-title {
      margin-bottom: 64px;
      margin: 0px 0px 32px;
      font-weight: 600;
      font-size: 40px;
      line-height: 48px;
      font-family: Roobert, Arial, Helvetica, sans-serif;
      color: rgb(38, 43, 56);
      text-transform: inherit;
      text-align: center;
    }

    .product-detail-item-box {
      display: flex;
      flex-direction: row;
      max-width: 1280px;
      margin: 0px auto;
      -webkit-box-align: center;
      align-items: center;
      -webkit-box-pack: justify;
      justify-content: space-between;
    }

    .product-detail-item-picture {
      background: rgb(216, 219, 230);
      max-width: 624px;
      max-height: 624px;
      width: 100%;
      aspect-ratio: 1 / 1;
      border-radius: 8px;
      overflow: hidden;
    }

    .product-detail-item-content {
      margin-left: 32px;
    }

    .product-detail-item-title {
      display: flex;
      margin-bottom: 16px;
    }

    .product-detail-item-title-text {
      margin: 0px;
      font-weight: 600;
      font-size: 40px;
      line-height: 48px;
      font-family: Roobert, Arial, Helvetica, sans-serif;
      color: rgb(38, 43, 56);
    }

    .product-detail-item-description {
      margin: 0px;
      font-weight: 400;
      font-size: 18px;
      line-height: 24px;
      color: rgb(88, 98, 128);
    }
  }
</style>

{% if section.settings.display_product_detail_description
  or section.settings.display_product_reviews
  or section.settings.display_custom_tab_1
  or section.settings.display_custom_tab_2
  or section.settings.display_custom_tab_3
  or section.settings.display_custom_tab_4
  or section.settings.display_custom_tab_5
  or section.settings.display_custom_tab_6
%}
  <div
    id="product-page-tabs"
    class="tabs__product-page horizontal-tabs{% if section.settings.show_tab == 'horizontal_center' %} horizontal-tabs-center{% endif %}"
  >
    {% if section.settings.display_product_detail_description == false
      and section.settings.display_product_reviews == true
    %}
      {% assign tab2_active = true %}
    {% elsif section.settings.display_product_detail_description == false
      and section.settings.display_product_reviews == false
      and section.settings.display_custom_tab_1 == true
    %}
      {% assign tab3_active = true %}
    {% elsif section.settings.display_product_detail_description == false
      and section.settings.display_product_reviews == false
      and section.settings.display_custom_tab_1 == false
      and section.settings.display_custom_tab_2 == true
    %}
      {% assign tab4_active = true %}
    {% elsif section.settings.display_product_detail_description == false
      and section.settings.display_product_reviews == false
      and section.settings.display_custom_tab_1 == false
      and section.settings.display_custom_tab_2 == false
      and section.settings.display_custom_tab_3 == true
    %}
      {% assign tab5_active = true %}
    {% elsif section.settings.display_product_detail_description == false
      and section.settings.display_product_reviews == false
      and section.settings.display_custom_tab_1 == false
      and section.settings.display_custom_tab_2 == false
      and section.settings.display_custom_tab_3 == false
      and section.settings.display_custom_tab_4 == true
    %}
      {% assign tab6_active = true %}
    {% elsif section.settings.display_product_detail_description == false
      and section.settings.display_product_reviews == false
      and section.settings.display_custom_tab_1 == false
      and section.settings.display_custom_tab_2 == false
      and section.settings.display_custom_tab_3 == false
      and section.settings.display_custom_tab_4 == false
      and section.settings.display_custom_tab_5 == true
    %}
      {% assign tab7_active = true %}
    {% elsif section.settings.display_product_detail_description == false
      and section.settings.display_product_reviews == false
      and section.settings.display_custom_tab_1 == false
      and section.settings.display_custom_tab_2 == false
      and section.settings.display_custom_tab_3 == false
      and section.settings.display_custom_tab_4 == false
      and section.settings.display_custom_tab_5 == false
      and section.settings.display_custom_tab_6 == true
    %}
      {% assign tab8_active = true %}
    {% endif %}
    <ul class="list-tabs">
      {% if section.settings.display_product_detail_description %}
        <li class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab1" class="tab-links active">
            {% render 'multilang' with section.settings.product_description_title %}
          </a>
        </li>
      {% endif %}

      {% if section.settings.display_product_reviews %}
        <li class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab2" class="tab-links {% if tab2_active%}active{% endif %}">
            {% render 'multilang' with section.settings.product_review_title %}
          </a>
        </li>
      {% endif %}

      {% if section.settings.display_custom_tab_1 %}
        <li class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab3" class="tab-links {% if tab3_active%}active{% endif %}">
            {% render 'multilang' with section.settings.custom_tab_title_1 %}
          </a>
        </li>
      {% endif %}

      {% if section.settings.display_custom_tab_2 %}
        <li class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab4" class="tab-links {% if tab4_active%}active{% endif %}">
            {% render 'multilang' with section.settings.custom_tab_title_2 %}
          </a>
        </li>
      {% endif %}

      {% if section.settings.display_custom_tab_3 %}
        <li class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab5" class="tab-links {% if tab5_active%}active{% endif %}">
            {% render 'multilang' with section.settings.custom_tab_title_3 %}
          </a>
        </li>
      {% endif %}

      {% if section.settings.display_custom_tab_4 %}
        <li class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab6" class="tab-links {% if tab6_active%}active{% endif %}">
            {% render 'multilang' with section.settings.custom_tab_title_4 %}
          </a>
        </li>
      {% endif %}

      {% if section.settings.display_custom_tab_5 %}
        <li class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab7" class="tab-links {% if tab7_active%}active{% endif %}">
            {% render 'multilang' with section.settings.custom_tab_title_5 %}
          </a>
        </li>
      {% endif %}
      {% if section.settings.display_custom_tab_6 %}
        <li class="tab-title">
          <a
            href="#featured-products-{{section.id | replace: "main","supermarket_featured_products_yr6kXD"}}"
            class="tab-links"
          >
            {% render 'multilang' with section.settings.custom_tab_title_6 %}
          </a>
        </li>
      {% endif %}
    </ul>

    <div class="wrapper-tab-content">
      {% if section.settings.display_product_detail_description %}
        {% assign des = product.description %}
        {% if des contains '[countdown]' or product.description contains '[custom tab]' %}
          {% assign des = product.description | split: '[/countdown]</p>' | last %}
          {% assign des = des | split: '[custom tab]' | first | split: '<iframe' | first %}
        {% endif %}
        <div class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab1" class="tab-links active">
            {% render 'multilang' with section.settings.product_description_title %}
            <span class="icon-dropdown">
              <i class="fa fa-angle-down"></i>
            </span>
          </a>
        </div>

        <div class="tab-content active" data-TabContent id="collapse-tab1">
          <div class="rte">
            {{ des }}
          </div>
          {% unless settings.product_layout == 'surfup' %}
            {% render 'product-banner' %}
          {% endunless %}
          {% render 'product-detail-gallery_lookbook', product: product %}
        </div>
      {% endif %}

      {% if section.settings.display_product_reviews %}
        <div class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab2" class="tab-links {% if tab2_active%}active{% endif %}">
            {% render 'multilang' with section.settings.product_review_title %}
            <span class="icon-dropdown">
              <i class="fa fa-angle-down"></i>
            </span>
          </a>
        </div>
        <div class="tab-content {% if tab2_active%}active{% endif %}" data-TabContent id="collapse-tab2">
          {% comment %}Start automatically added Judge.me widget{% endcomment %}
          {% render 'judgeme_widgets',
            widget_type: 'judgeme_review_widget',
            concierge_install: true,
            product: product
          %}
          {% comment %}End automatically added Judge.me widget{% endcomment %}
          <div id="shopify-product-reviews" data-id="{{product.id}}">
            {{ product.metafields.spr.reviews }}
          </div>
        </div>
      {% endif %}

      {% if section.settings.display_custom_tab_1 %}
        <div class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab3" class="tab-links {% if tab3_active%}active{% endif %}">
            {% render 'multilang' with section.settings.custom_tab_title_1 %}
            <span class="icon-dropdown">
              <i class="fa fa-angle-down"></i>
            </span>
          </a>
        </div>
        <div class="tab-content {% if tab3_active%}active{% endif %}" data-TabContent id="collapse-tab3">
          {% if product.metafields.c_f.custom_tab1 != blank %}
            {% assign des = product.metafields.c_f.custom_tab1 %}
            <div>
              {{ des }}
            </div>
          {% else %}
            {% assign des = section.settings.custom_tab_content_1 %}
            <div>
              {{ des }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.display_custom_tab_2 %}
        <div class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab4" class="tab-links {% if tab4_active %}active{% endif %}">
            {% render 'multilang' with section.settings.custom_tab_title_2 %}
            <span class="icon-dropdown">
              <i class="fa fa-angle-down"></i>
            </span>
          </a>
        </div>
        <div class="tab-content {% if tab4_active %}active{% endif %}" data-TabContent id="collapse-tab4">
          {% if product.metafields.c_f.custom_tab2 != blank %}
            {% assign des = product.metafields.c_f.custom_tab2 %}
            <div>
              {{ des }}
            </div>
          {% else %}
            {% assign des = section.settings.custom_tab_content_2 %}
            <div>
              {{ des }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.display_custom_tab_3 %}
        <div class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab5" class="tab-links {% if tab5_active%}active{% endif %}">
            {% render 'multilang' with section.settings.custom_tab_title_3 %}
            <span class="icon-dropdown">
              <i class="fa fa-angle-down"></i>
            </span>
          </a>
        </div>
        <div class="tab-content {% if tab5_active%}active{% endif %}" data-TabContent id="collapse-tab5">
          {% if product.metafields.c_f.custom_tab3 != blank %}
            {% assign des = product.metafields.c_f.custom_tab3 %}
            <div>
              {{ des }}
            </div>
          {% else %}
            {% assign des = section.settings.custom_tab_content_3 %}
            <div>
              {{ des }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.display_custom_tab_4 %}
        <div class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab6" class="tab-links {% if tab6_active%}active{% endif %}">
            {% render 'multilang' with section.settings.custom_tab_title_4 %}
            <span class="icon-dropdown">
              <i class="fa fa-angle-down"></i>
            </span>
          </a>
        </div>
        <div class="tab-content {% if tab6_active%}active{% endif %}" data-TabContent id="collapse-tab6">
          {% if product.metafields.c_f.custom_tab4 != blank %}
            {% assign des = product.metafields.c_f.custom_tab4 %}
            <div>
              {{ des }}
            </div>
          {% else %}
            {% assign des = section.settings.custom_tab_content_4 %}
            <div>
              {{ des }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.display_custom_tab_5 %}
        <div class="tab-title">
          <a href="#" data-tapTop data-target="#collapse-tab7" class="tab-links {% if tab7_active%}active{% endif %}">
            {% render 'multilang' with section.settings.custom_tab_title_5 %}
            <span class="icon-dropdown">
              <i class="fa fa-angle-down"></i>
            </span>
          </a>
        </div>
        <div class="tab-content {% if tab7_active%}active{% endif %}" data-TabContent id="collapse-tab7">
          {% assign collection_faq = nil %}
          {% for collection in product.collections %}
            {% if collection.metafields.custom.collection_for_product_faq != blank %}
              {% assign collection_faq = collection.metafields.custom.collection_for_product_faq %}
              {% break %}
            {% endif %}
          {% endfor %}

          {% if collection_faq %}
            <div>{{ collection_faq }}</div>
          {% elsif product.metafields.c_f.custom_tab5 != blank %}
            {% assign des = product.metafields.c_f.custom_tab5 %}
            <div>
              {{ des }}
            </div>
          {% else %}
            {% assign des = section.settings.custom_tab_content_5 %}
            <div>
              {{ des }}
            </div>
          {% endif %}
          
        </div>
      {% endif %}
      {% comment %}
        {% if section.settings.display_custom_tab_6 %}
          <div class="tab-title">
            <a href="#" data-tapTop data-target="#collapse-tab8" class="tab-links {% if tab8_active%}active{% endif %}">
              {% render 'multilang' with section.settings.custom_tab_title_6 %}
              <span class="icon-dropdown">
                <i class="fa fa-angle-down"></i>
              </span>
            </a>
          </div>
          <div class="tab-content {% if tab8_active%}active{% endif %}" data-TabContent id="collapse-tab8">
            {%- assign row = 'five-items' -%}
            {%  assign collection_results_per_row = 5 %}
            {%  assign slider_featured_limit_all = 10 %}

            <div class="recommendation-box">
              <h3 align="center">People Who Bought This Item Also Bought</h3>
              <div
                class="suppermarket-featured-products featured-products"
                id="featured-products-{{section.id}}"
                data-featured-products-section-2
                {% if section.settings.recommend_collection != blank %}
                  data-loader-product data-collection="{{section.settings.recommend_collection}}"
                  data-limit="{{ slider_featured_limit_all }}"
                  data-grid="{{ collection_results_per_row }}" data-layout="carousel"
                  sectionId="{{section.id}}"
                {% endif %}
              >
                <div class="container">
                  <div class="row">
                    <div class="col-12">
                      <div class="widget-product suppermarket-widget-product">
                        <div
                          class="products-grid row {{ row }}"
                          data-row="{{ collection_results_per_row }}"
                        >
                          {% for product in collections[section.settings.recommend_collection].products
                            limit: slider_featured_limit_all
                          %}
                            <div class="grid-item {{ grid_item_width }}{% if settings.product_image_border %} grid-item-border{% endif %}">
                              {% render 'before-load-grid-item', product: product %}
                            </div>

                          {% else %}
                            {% for product in (1..slider_featured_limit_all) %}
                              <div class="grid-item {{ grid_item_width }}">
                                <div class="grid-view-item no-product">
                                  <div class="product-top">
                                    <div class="not_img">Product Img</div>
                                  </div>

                                  <div class="product-bottom">
                                    <div class="product-title">
                                      <span> Your product's name </span>
                                    </div>

                                    <div class="price-box">
                                      <span> $250.00 </span>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            {% endfor %}
                          {% endfor %}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      {% endcomment %}
    </div>
  </div>
{% endif %}
