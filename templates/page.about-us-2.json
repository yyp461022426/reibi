    "about_us_first_intro_iGAUcN": {
      "type": "about-us-first-intro",
      "settings": {
        "title": "About Us",
        "description": "You can contact us at support@reibii.com. REIBII is our independently designed and established brand. We're dedicated to offering a variety of storage solutions that help you create a more organized home and workspace.We understand that every customer's needs are unique, so we focus on your experience, designing products that are not only practical and durable but also seamlessly inte-grate into your space. Our goal is to provide you with high-quality solutions at affordable prices, making it easy for every household to achieve their ideal storage setup. With RElBll, you can expect satisfaction from start to finish, We look forward to being your trusted storage expert!"
      }
    },
    "about_us_advantage_EWJQqr": {
      "type": "about-us-advantage",
      "blocks": {
        "item_show_wDzqU3": {
          "type": "item-show",
          "settings": {
            "item_img": "shopify://shop_images/about_adv_3.png",
            "item_title": "Built to Last & User-Friendly",
            "item_des": "Our storage solutions use durable steel or eco-friendly wood, designed for heavy loads, corrosion resistance, and easy assembly. Each product is rigorously tested to ensure long-lasting quality and user-friendly setup for reliable and convenient storage."
          }
        },
        "item_show_pJFLPb": {
          "type": "item-show",
          "settings": {
            "item_img": "shopify://shop_images/2_bf676728-c891-4fc7-b473-eb312f2d259b.jpg",
            "item_title": "Fast Delivery & Budget-Friendly",
            "item_des": "Delivery takes only 3-8 business days. We have strategic warehouses in many places in the United States, which can provide fast delivery services and significantly shorten transportation time. This network helps to reduce logistics costs, improve delivery efficiency, and ensure that your orders are delivered quickly and reliably."
          }
        },
        "item_show_mJGDg9": {
          "type": "item-show",
          "settings": {
            "item_img": "shopify://shop_images/about_adv_2.png",
            "item_title": "Professional Support",
            "item_des": "At REIBII, we provide personalized service from pre-purchase to post-purchase, ensuring your satisfaction. With expert advice, easy returns, quick responses, and dedicated support, we prioritize a seamless and enjoyable customer experience. Service Time: Monday to Sunday: 9:00am - 10:00pm (Saturday: Closed) (PST Time)"
          }
        }
      },
      "block_order": [
        "item_show_wDzqU3",
        "item_show_pJFLPb",
        "item_show_mJGDg9"
      ],
      "settings": {}
    },
    "dfba0c81-9548-4fbc-af89-db9b327912f5": {
