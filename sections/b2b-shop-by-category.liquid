<link rel="stylesheet" type="text/css" href="{{ 'b2b-shop-by-category.css' | asset_url }}">
<div class="b2b-shop-by-category normal-floor">
  <div class="container">
    {% if section.settings.title and section.settings.title != '' %}
      <h2 class="main-page-title">
        <span class="small-title">{{ section.settings.title | upcase }}</span>
        <span class="text-shadow">{{ section.settings.title | upcase }}</span>
      </h2>
    {% endif %}
    <div class="series-box">
      <div class="series-box-view b2b-category-slick-scroll line-dots">
        {% for block in section.blocks limit: 30 %}
          <a href="{{ block.settings.link }}" class="series-item">
            <div class="img-box">
              {% if block.settings.series_img != blank %}
                {{ block.settings.series_img | image_url: width: 380 | image_tag: class: 'series-img' }}
              {% else %}
                <div class="not_img">210 x 210px</div>
              {% endif %}
            </div>
            <div class="category-name">{{ block.settings.category_name }}</div>
          </a>
        {% endfor %}
      </div>
    </div>
    <div class="pdf-link">{{ section.settings.pdf_link }}</div>
  </div>
</div>
<script>
  $(document).ready(function () {
    $('.b2b-category-slick-scroll').slick({
      dots: false,
      infinite: true,
      slidesToShow: 5,
      slidesToScroll: 1,
      adaptiveHeight: true,
      get nextArrow() {
        return (this.nextArrow =
          '<button type="button" aria-label="Next" class="slick-next"><svg viewBox="0 0 478.448 478.448" class="icon icon-chevron-right" id="icon-chevron-right"><g><g><polygon points="131.659,0 100.494,32.035 313.804,239.232 100.494,446.373 131.65,478.448 377.954,239.232"></polygon></g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g></svg></button>');
      },
      get prevArrow() {
        return (this.prevArrow =
          '<button type="button" aria-label="Previous" class="slick-prev"><svg viewBox="0 0 370.814 370.814" class="icon icon-chevron-left" id="icon-chevron-left"><g><g><polygon points="292.92,24.848 268.781,0 77.895,185.401 268.781,370.814 292.92,345.961 127.638,185.401"></polygon></g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g><g></g></svg></button>');
      },
      responsive: [
        {
          breakpoint: 1024,
          settings: {
            dots: false,
            slidesToShow: 4,
            slidesToScroll: 1,
          },
        },
        {
          breakpoint: 500,
          settings: {
            dots: true,
            slidesToShow: 3,
            slidesToScroll: 1,
          },
        },
        {
          breakpoint: 350,
          settings: {
            dots: true,
            slidesToShow: 2,
            slidesToScroll: 1,
          },
        },
      ],
    });
    setTimeout(function () {
      $('.category-slick-scroll').slick('refresh');
      $('.category-slick-scroll').css('opacity', '1');
    }, 100);
  });
</script>
{% schema %}
{
  "name": "B2b Shop By Category",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title"
    },
    {
      "type": "inline_richtext",
      "id": "pdf_link",
      "label": "PDFLink"
    }
  ],
  "blocks": [
    {
      "name": "Every block",
      "type": "card-show",
      "settings": [
        {
          "type": "image_picker",
          "id": "series_img",
          "label": "Series Image"
        },
        {
          "type": "text",
          "id": "category_name",
          "label": "Category Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection Link of This Series"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "B2b Shop By Category"
    }
  ]
}
{% endschema %}
