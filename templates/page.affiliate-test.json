    "accordion_component_rHVW8A": {
      "type": "accordion-component",
      "blocks": {
        "block_show_xrJpfE": {
          "type": "block-show",
          "settings": {
            "setp_title": "What is affiliate marketing?",
            "text_step_des": "<p>Affiliate marketing allows you to earn commissions by promoting products or services. Affiliates make money by directing customers to make purchases through their unique links.<\/p>"
          }
        },
        "block_show_TEF7Y9": {
          "type": "block-show",
          "settings": {
            "setp_title": "How can I join your affiliate program?",
            "text_step_des": "<p>You can apply through our registration page. <\/p><p>Impact registration link: <a href=\"http:\/\/app.impact.com\/campaign-campaign-info-v2\/Reibii.brand\" title=\"http:\/\/app.impact.com\/campaign-campaign-info-v2\/Reibii.brand\">http:\/\/app.impact.com\/campaign-campaign-info-v2\/Reibii.brand<\/a>; <\/p><p>ShareASale registration link: <a href=\"http:\/\/www.shareasale.com\/join\/134627\" target=\"_blank\" title=\"http:\/\/www.shareasale.com\/join\/134627\">http:\/\/www.shareasale.com\/join\/134627<\/a>.  <\/p><p>We will contact you with the next steps after reviewing your application.<\/p>"
          }
        },
        "block_show_N98Hg9": {
          "type": "block-show",
          "settings": {
            "setp_title": "What is the commission structure?",
            "text_step_des": "<p>Our commission rates vary based on the product and sales volume. For detailed information, please visit our commission page.<\/p>"
          }
        },
        "block_show_mALCJc": {
          "type": "block-show",
          "settings": {
            "setp_title": "How can I track my sales and commissions?",
            "text_step_des": "<p>You can monitor your sales data and commission balance through affiliate dashboard.<\/p>"
          }
        },
        "block_show_6bbaAX": {
          "type": "block-show",
          "settings": {
            "setp_title": "What promotional materials are provided?",
            "text_step_des": "<p>We offer a variety of promotional materials, including banners, text links, and product images, which you can use on your website or social media.<\/p>"
          }
        },
        "block_show_JmxD7B": {
          "type": "block-show",
          "settings": {
            "setp_title": "How is commission payment processed?",
            "text_step_des": "<p>Commissions are locked 30 days after order placement and paid at the end of each month via your selected payment method.<\/p>"
          }
        },
        "block_show_PkimY9": {
          "type": "block-show",
          "settings": {
            "setp_title": "Can I promote multiple products simultaneously?",
            "text_step_des": "<p>Absolutely! We encourage you to promote all our products to maximize your earning potential.<\/p>"
          }
        },
        "block_show_nDWXna": {
          "type": "block-show",
          "settings": {
            "setp_title": "How can I reach out if I have questions?",
            "text_step_des": "<p>You can contact us via email <em><strong>affiliate@reibii.com<\/strong><\/em>, and we will respond promptly.<\/p>"
          }
        }
      },
