<!-- Footer scripts -->
<script defer src="{{ 'vendor.min.js' | asset_url }}"></script>
<script async src="{{ 'api.jquery.js' | asset_url }}"></script>
<script async src="{{ 'option_selection.js' | shopify_asset_url }}"></script>
{%  render 'new-currency' %}
<script defer src="{{ 'jquery.sticky.js' | asset_url }}"></script>
<script defer src="https://cdn.jsdelivr.net/npm/clipboard@2.0.6/dist/clipboard.min.js"></script>
{% comment %} <script src="{{ 'ella.min.js' | asset_url }}"></script> {% endcomment %}
<script defer src="{{ 'animations.js' | asset_url }}"></script>
{% comment %} <script defer src="{{ 'halo.js' | asset_url }}"></script> {% endcomment %}
{% render 'hs-minify-js' with filename: 'halo.js', defer: true %}

{% if template contains 'collection' %}
<script>
  $(document).ready(function(){
    $('.dropdown-cat a').each(function(){
      if($(this).hasClass('active')) {
        $(this).parents('li').addClass('open');
      }
    });
  })
</script>
{% endif %}
{% if settings.redirect_button == 'none' %}
<script>
  $(document).ready(function(){
    $("#reload_page").on("click", function(){
      $('html').removeClass("cart-show");
    });
  })
</script>
{% endif %}
<script>
$(document).ready(function(){
  $('[data-toggle="tooltip"]').tooltip();
});
</script>
