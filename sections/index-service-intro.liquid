<link rel="stylesheet" type="text/css" href="{{ 'index-service-intro.css' | asset_url }}">
<div class="index-service-intro container index-normal-component">
  <div class="deals-box">
    {% if section.settings.title and section.settings.title != '' %}
      <h2 class="main-page-title {% if section.settings.title_add_desc %}with-desc{% endif %}">
        {% if section.settings.title_style == '1' %}
          <span class="small-title">{{ section.settings.title | upcase }}</span>
          <span class="text-shadow">{{ section.settings.title | upcase }}</span>
        {% else %}
          <span class="small-title2">{{ section.settings.title }}</span>
        {% endif %}
      </h2>
      {% if section.settings.title_add_desc %}
        <div class="desc-add">
          {{ section.settings.title_add_desc }}
        </div>
      {% endif %}
    {% endif %}
  </div>
  <div class="content-box">
    <div class="bigger-card-content">
      {% if section.settings.is_bigger_card1 %}
        <div class="bigger-card-item">
          <div class="bigger-card-header">
            <div class="card-title">{{ section.settings.card_title_1 }}</div>
            <div class="card-desc">
              {{ section.settings.card_desc_1 }}
            </div>
          </div>
          <div
            class="bigger-card-count"
            style="{% if section.settings.bigger_card_link_1 == blank %}margin-bottom: 0;{% endif %}"
          >
            <div class="count-item">
              <div class="count">{{ section.settings.card_count_1_1 }}</div>
              <div class="count-desc">{{ section.settings.card_desc_1_1 }}</div>
            </div>
            <div class="count-item">
              <div class="count">{{ section.settings.card_count_1_2 }}</div>
              <div class="count-desc">{{ section.settings.card_desc_1_2 }}</div>
            </div>
            <div class="count-item">
              <div class="count">{{ section.settings.card_count_1_3 }}</div>
              <div class="count-desc">{{ section.settings.card_desc_1_3 }}</div>
            </div>
          </div>
          {% if section.settings.bigger_card_link_1 != blank %}
            <div class="started-now">
              <a class="start-link custom-action-btn action-empty-btn" href="{{ section.settings.bigger_card_link_1 }}"
                >Get Started Now!</a
              >
            </div>
          {% endif %}
        </div>
      {% endif %}
      {% if section.settings.is_bigger_card2 %}
        <div class="bigger-card-item">
          <div class="bigger-card-header">
            <div class="card-title">{{ section.settings.card_title_2 }}</div>
            <div class="card-desc">
              {{ section.settings.card_desc_2 }}
            </div>
          </div>
          <div
            class="bigger-card-count"
            style="{% if section.settings.bigger_card_link_2 == blank %}margin-bottom: 0;{% endif %}"
          >
            <div class="count-item">
              <div class="count">{{ section.settings.card_count_2_1 }}</div>
              <div class="count-desc">{{ section.settings.card_desc_2_1 }}</div>
            </div>
            <div class="count-item">
              <div class="count">{{ section.settings.card_count_2_2 }}</div>
              <div class="count-desc">{{ section.settings.card_desc_2_2 }}</div>
            </div>
            <div class="count-item">
              <div class="count">{{ section.settings.card_count_2_3 }}</div>
              <div class="count-desc">{{ section.settings.card_desc_2_3 }}</div>
            </div>
          </div>
          {% if section.settings.bigger_card_link_2 != blank %}
            <div class="started-now">
              <a class="start-link custom-action-btn action-empty-btn" href="{{ section.settings.bigger_card_link_2 }}"
                >Get Started Now!</a
              >
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
    <div class="more-info">
      <a class="custom-action-btn action-full-btn" href="{{ section.settings.first_url }}">MORE INFO!</a>
    </div>
    <div
      class="sm-card-swiper line-dots"
      data-loader-script="{{ 'halo.slide-custom.js' | asset_url }}"
      slide-custom-init
      data-mb-dots="true"
      data-arrow-enable="true"
      data-mb-slides-to-show="2"
    >
      {% for block in section.blocks limit: 3 %}
        <div class="card-item">
          <div class="card-title">{{ block.settings.card_title }}</div>
          <div class="card-count">{{ block.settings.card_count }}</div>
          <div class="card-desc">{{ block.settings.card_desc }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Index Service Intro",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title"
    },
    {
      "type": "radio",
      "id": "title_style",
      "label": "Title Style",
      "options": [
        {
          "value": "1",
          "label": "Title Style1(叠影)"
        },
        {
          "value": "2",
          "label": "Title Style1(单色)"
        }
      ],
      "default": "1"
    },
    {
      "type": "text",
      "id": "title_add_desc",
      "label": "标题下方的描述"
    },
    {
      "type": "url",
      "id": "first_url",
      "label": "More Info Link To"
    },
    {
      "type": "header",
      "content": "大卡片1=============="
    },
    {
      "type": "checkbox",
      "id": "is_bigger_card1",
      "label": "是否展示大卡片1?",
      "default": true
    },
    {
      "type": "text",
      "id": "card_title_1",
      "label": "大卡片1标题"
    },
    {
      "type": "textarea",
      "id": "card_desc_1",
      "label": "大卡片1描述"
    },
    {
      "type": "text",
      "id": "card_count_1_1",
      "label": "大卡片1的第一个计数"
    },
    {
      "type": "text",
      "id": "card_desc_1_1",
      "label": "大卡片1的第一个计数下的描述"
    },
    {
      "type": "text",
      "id": "card_count_1_2",
      "label": "大卡片1的第二个计数"
    },
    {
      "type": "text",
      "id": "card_desc_1_2",
      "label": "大卡片1的第二个计数下的描述"
    },
    {
      "type": "text",
      "id": "card_count_1_3",
      "label": "大卡片1的第三个计数"
    },
    {
      "type": "text",
      "id": "card_desc_1_3",
      "label": "大卡片1的第三个计数下的描述"
    },
    {
      "type": "url",
      "id": "bigger_card_link_1",
      "label": "大卡片1的链接"
    },
    {
      "type": "header",
      "content": "大卡片2=============="
    },
    {
      "type": "checkbox",
      "id": "is_bigger_card2",
      "label": "是否展示大卡片2?",
      "default": true
    },
    {
      "type": "text",
      "id": "card_title_2",
      "label": "大卡片2标题"
    },
    {
      "type": "textarea",
      "id": "card_desc_2",
      "label": "大卡片2描述"
    },
    {
      "type": "text",
      "id": "card_count_2_1",
      "label": "大卡片2的第一个计数"
    },
    {
      "type": "text",
      "id": "card_desc_2_1",
      "label": "大卡片2的第一个计数下的描述"
    },
    {
      "type": "text",
      "id": "card_count_2_2",
      "label": "大卡片2的第二个计数"
    },
    {
      "type": "text",
      "id": "card_desc_2_2",
      "label": "大卡片2的第二个计数下的描述"
    },
    {
      "type": "text",
      "id": "card_count_2_3",
      "label": "大卡片2的第三个计数"
    },
    {
      "type": "text",
      "id": "card_desc_2_3",
      "label": "大卡片2的第三个计数下的描述"
    },
    {
      "type": "url",
      "id": "bigger_card_link_2",
      "label": "大卡片2的链接"
    }
  ],
  "blocks": [
    {
      "name": "Every block",
      "type": "card-show",
      "settings": [
        {
          "type": "text",
          "id": "card_title",
          "label": "Card Title"
        },
        {
          "type": "textarea",
          "id": "card_count",
          "label": "Card Count"
        },
        {
          "type": "textarea",
          "id": "card_desc",
          "label": "卡片描述"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Index Service Intro"
    }
  ]
}
{% endschema %}
