<div class="header-mb {% if settings.header_style_mobile == 'header_mobile_2' %}header_mobile_2{% elsif settings.header_style_mobile == 'header_mobile_3' %}header_mobile_3{% endif %}">
  <div class="header-first-level">
    <div class="header-mb-left header-mb-items{% unless settings.enable_search %} no-search{% endunless %}{% unless shop.customer_accounts_enabled %} no-account{% endunless %}">
      <div class="hamburger-icon svg-mb">
        <a href="#" class="icon-nav close-menu-mb" title="Menu Mobile Icon" data-menu-mb-toogle>
          <span class="icon-line"></span>
        </a>
      </div>

      {% unless settings.header_style_mobile == 'header_mobile_3' %}
        {% if shop.customer_accounts_enabled %}
          <div class="acc-mb svg-mb">
            <a href="{{ routes.account_url }}" title="User Icon" class="icon-user" data-user-mobile-toggle>
              {% if settings.header_layout == '05' %}
                {% render 'icons8-male-user' %}
              {% elsif settings.header_layout == '06' %}
                {% render 'icon-user-2' %}
              {% elsif settings.header_layout == '07' %}
                {% render 'icons7-user' %}
              {% else %}
                {% comment %}
                  <img
                    src="https://cdn.shopify.com/s/files/1/0632/4833/5096/files/user_1.1.png?v=1721966364"
                    width="21"
                    height="23"
                    alt="User"
                  >
                {% endcomment %}
                {% render 'icon-user-3' %}
                {% comment %} {% render 'icon-user' %} {% endcomment %}
              {% endif %}
            </a>
            {%- render 'remind-login-pop' -%}
          </div>
        {% endif %}
      {% endunless %}

      {% comment %}
        {% if settings.header_style_mobile == 'header_mobile_1' %}
          {% if settings.enable_search %}
            <div class="search-mb svg-mb">
              <a href="#" title="Search Icon" class="icon-search" data-search-mobile-toggle>
                <img
                  src="https://cdn.shopify.com/s/files/1/0632/4833/5096/files/search_1.1.png?v=1721966364"
                  width="21"
                  height="21"
                  alt="Search"
                >
              </a>

              <a href="#" title="close" class="close close-search">
                {% render 'icon-close' %}
              </a>

            </div>
          {% endif %}
        {% endif %}
      {% endcomment %}

      {% if settings.header_style_mobile == 'header_mobile_2' %}
        <div class="header-logo">
          {% if section.settings.brand_type == 'image' and section.settings.logo != bank %}
            <a class="logo-img" href="{{ routes.cart_url | split: 'cart' | first }}" title="Logo">
              <img
                data-src="{{ section.settings.logo | img_url: 'master' }}"
                src="{{ section.settings.logo | img_url: 'master' }}"
                alt="{{ section.settings.logo.alt | default: shop.name }}"
                itemprop="logo"
                class="lazyautosizes lazyloade"
                data-sizes="auto"
              >
            </a>
          {% elsif section.settings.brand_text != '' %}
            <a class="logo-title" href="{{ routes.cart_url | split: 'cart' | first }}">
              {{ section.settings.brand_text }}
            </a>
          {% else %}
            <a class="logo-title" href="{{ routes.cart_url | split: 'cart' | first }}">
              {{ shop.name }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="header-mb-middle header-mb-items{% unless shop.customer_accounts_enabled %} no-account{% endunless %}{% unless settings.enable_search %} no-search{% endunless %}">
      {% if settings.header_style_mobile == 'header_mobile_1' or settings.header_style_mobile == 'header_mobile_3' %}
        <div class="header-logo">
          {% if section.settings.brand_type == 'image' and section.settings.logo != bank %}
            <a class="logo-img" href="{{ routes.cart_url | split: 'cart' | first }}" title="Logo">
              <img
                data-src="{{ section.settings.logo | img_url: 'master' }}"
                src="{{ section.settings.logo | img_url: 'master' }}"
                alt="{{ section.settings.logo.alt | default: shop.name }}"
                itemprop="logo"
                class="lazyautosizes lazyloade"
                data-sizes="auto"
              >
            </a>
          {% elsif section.settings.brand_text != '' %}
            <a class="logo-title" href="{{ routes.cart_url | split: 'cart' | first }}">
              {{ section.settings.brand_text }}
            </a>
          {% else %}
            <a class="logo-title" href="{{ routes.cart_url | split: 'cart' | first }}">
              {{ shop.name }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="header-mb-right header-mb-items{% unless settings.enable_search %} no-search{% endunless %}{% unless shop.customer_accounts_enabled %} no-account{% endunless %}">
      {% if settings.header_style_mobile == 'header_mobile_2' or settings.header_style_mobile == 'header_mobile_3' %}
        {% if settings.enable_search %}
          <div class="search-mb svg-mb">
            <a href="#" title="Search Icon" class="icon-search" data-search-mobile-toggle>
              <img
                src="https://cdn.shopify.com/s/files/1/0632/4833/5096/files/search_1.1.png?v=1721966364"
                width="21"
                height="21"
                alt="Search"
              >
              {% comment %} {% render 'icon-search' %} {% endcomment %}
            </a>

            <a href="#" title="close" class="close close-search">
              {% render 'icon-close' %}
            </a>

            {% render 'search-bar' %}
          </div>
        {% endif %}
      {% endif %}

      <div class="cart-icon svg-mb">
        <a href="#" title="Cart Icon" data-cart-toggle>
          {% if settings.header_layout == '05' or settings.header_layout == '07' %}
            {% render 'icons8-shopping-bag' %}
          {% elsif settings.header_layout == '06' %}
            {% render 'icon-cart-2' %}
          {% else %}
            {% comment %}
              <img
                src="https://cdn.shopify.com/s/files/1/0632/4833/5096/files/cart_1.1.png?v=1721966364"
                width="24"
                height="22"
                alt="add to cart"
              >
            {% endcomment %}
            {% render 'icon-cart-3' %}
          {% endif %}
          <span class="cartCount" data-cart-count>
            {{ cart.item_count }}
          </span>
        </a>
      </div>
    </div>
  </div>
  <div class="mb-header-search-box">
    <div data-search-mobile-toggle>
      <div class="mb-search-box">
        <button class="mb-search-icon" aria-label="Search">
          <svg t="1758693170509" class="icon" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg" p-id="4776" width="200" height="200"><path d="M883.2 832l-140.8-140.8c57.6-70.4 83.2-153.6 76.8-243.2-6.4-89.6-51.2-172.8-115.2-230.4C640 160 550.4 128 460.8 128c-83.2 0-166.4 38.4-230.4 102.4S128 377.6 128 467.2c0 83.2 32 172.8 89.6 236.8 57.6 64 140.8 108.8 230.4 115.2 89.6 6.4 172.8-19.2 243.2-76.8l140.8 140.8c6.4 6.4 6.4 6.4 12.8 6.4h25.6c6.4 0 6.4-6.4 12.8-6.4 6.4-6.4 6.4-6.4 6.4-12.8v-12.8-12.8c0-6.4 0-12.8-6.4-12.8z m-409.6-89.6c-51.2 0-102.4-12.8-147.2-44.8-44.8-32-83.2-70.4-102.4-121.6-19.2-44.8-25.6-102.4-12.8-153.6 12.8-51.2 38.4-102.4 70.4-140.8 38.4-38.4 83.2-64 134.4-70.4 57.6-12.8 108.8-6.4 160 12.8 51.2 19.2 89.6 57.6 121.6 96 32 44.8 44.8 96 44.8 147.2 0 70.4-25.6 140.8-76.8 192-51.2 57.6-121.6 83.2-192 83.2z" fill="#8d96ab" p-id="4777"></path></svg>
        </button>
        <div class="mb-search-input">What are you looking for?</div>
      </div>
    </div>
  </div>
</div>
