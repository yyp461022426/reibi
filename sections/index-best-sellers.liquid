<link
  rel="stylesheet"
  type="text/css"
  href="{{ 'index-best-sellers.css' | asset_url }}"
>
{%- assign render_slide = 'card-slide-show-' | append: section.id -%}
{%- assign card_selector = '.' | append: render_slide -%}
<div class="index-best-sellers index-normal-component">
  <div class="container">
    {% if section.settings.title and section.settings.title != '' %}
      <div class="show-mb">
        <h2 class="main-page-title {% if section.settings.title_add_desc %}with-desc{% endif %}">
          {% if section.settings.title_style == '1' %}
            <span class="small-title">{{ section.settings.title | upcase }}</span>
            <span class="text-shadow">{{ section.settings.title | upcase }}</span>
          {% else %}
            <span class="small-title2">{{ section.settings.title }}</span>
          {% endif %}
        </h2>
        {% if section.settings.title_add_desc %}
          <div class="desc-add">
            {{ section.settings.title_add_desc }}
          </div>
        {% endif %}
      </div>
    {% endif %}
    <div class="deals-box">
      <h2 class="deals-title">{{ section.settings.title | upcase }}</h2>
      <!-- 商品展示 -->
      <div class="products-show-box deals-box-mb">
        <div class="tab-content" style="opacity: 0;">
          <div class="index-normal-product-card {{ render_slide }} line-dots">
            {% for product in section.settings.collection.products limit: 8 %}
              {% assign index = forloop.index0 %}
              {% assign remainder = index | modulo: 2 %}
              {%- assign current_variant = product.selected_or_first_available_variant -%}
              {% if remainder == 0 %}
                <!-- 每组的开始 -->
                <div class="slick-slide-row">
              {%- endif -%}
              <a class="product-item" href="{{ product.url | within: collection }}" loader-img-box>
                <div class="item-card">
                  <div class="info-box">
                    <div class="img-box">
                      <div class="img-pic">
                        {% if product.available == false %}
                          <strong class="sold-out">Sold Out</strong>
                        {% elsif current_variant.compare_at_price
                          and current_variant.compare_at_price != 0
                          and current_variant.available
                        %}
                          <div class="deals-on">
                            <strong class="deal-num">
                              -
                              {{-
                                current_variant.compare_at_price
                                | minus: current_variant.price
                                | times: 100.0
                                | divided_by: current_variant.compare_at_price
                                | round
                              -}}
                              %
                            </strong>
                            <strong class="deal-off"> OFF </strong>
                          </div>
                        {% endif %}
                        {% if product.metafields.custom.show_on_main_page %}
                          {{
                            product.metafields.custom.show_on_main_page
                            | image_url: width: 214, height: 214
                            | image_tag: class: 'pro-img'
                          }}
                        {% else %}
                          {{ product.images | last | image_url: width: 214, height: 214 | image_tag: class: 'pro-img' }}
                        {% endif %}
                      </div>
                    </div>
                    <div class="item-options">
                      <div class="pro-title">{{ product.title }}</div>
                      <div class="pro-price">
                        <div class="price">
                          {% if current_variant.compare_at_price and current_variant.compare_at_price != 0 %}
                            <div class="min-price">{{ current_variant.price | money }}</div>
                            <div class="max-price">{{ current_variant.compare_at_price | money }}</div>
                          {% else %}
                            <div class="normal-price">{{ current_variant.price | money }}</div>
                          {% endif %}
                        </div>
                      </div>
                      {% if product.metafields.custom.dimension %}
                        <div class="pro-param pro-size">
                          <span>{{ product.metafields.custom.dimension }}</span>
                        </div>
                      {% endif %}
                      {% if product.metafields.custom.load_capacity %}
                        <div class="pro-param pro-weight">
                          <span>{{ product.metafields.custom.load_capacity }}</span>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                  <div class="option-box">
                    <div class="purchase-btn" data-id="{{product.variants[0].id}}">Buy Now</div>
                    {% if product.available %}
                      {% render 'icon-cart-3' %}
                      {% comment %}
                        <img
                          src="https://cdn.shopify.com/s/files/1/0632/4833/5096/files/cart_1.1.png?v=1721966364"
                          width="24"
                          height="22"
                          class="add-to-cart"
                          data-id="{{product.variants[0].id}}"
                          alt="add to cart"
                        >
                      {% endcomment %}
                    {% else %}
                      <div class="sold-out-note">Sold Out</div>
                    {% endif %}
                  </div>
                </div>
              </a>
              {% if remainder == 1 or forloop.last %}
                <!-- 每组的结束 -->
                </div>
              {% endif %}
            {% endfor %}
          </div>
          {%- if section.settings.enable_go_collection -%}
            <div class="flex-center collection-link">
              <button
                class="custom-action-btn action-empty-btn"
                data-url="{{ section.settings.collection.url }}"
                custom-link-btn
              >
                MORE INFO
              </button>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  $(document).ready(function () {
    $('{{ card_selector }}').slick({
      dots: false,
      infinite: true,
      slidesToShow: 2,
      slidesToScroll: 2,
      adaptiveHeight: true,
      get nextArrow() {
        return (this.nextArrow = `<button type="button" aria-label="Next" class="slick-next">
          <svg t="1758703771314" class="icon" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg" p-id="19663" width="16" height="16">
          <path d="M413.696 494.364444l265.272889-216.348444a28.444444 28.444444 0 1 0-35.953778-44.032L351.800889 471.438222a28.444444 28.444444 0 0 0-0.853333 43.349334l291.214222 257.479111a28.444444 28.444444 0 1 0 37.660444-42.666667L413.696 494.364444z" transform="scale(-1, 1) translate(-1024, 0)" p-id="19664">
          </path>
          </svg>
          </button>`);
      },
      get prevArrow() {
        return (this.prevArrow = `<button type="button" aria-label="Previous" class="slick-prev">
                <svg t="1758703771314" class="icon" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg" p-id="19663" width="16" height="16">
          <path d="M413.696 494.364444l265.272889-216.348444a28.444444 28.444444 0 1 0-35.953778-44.032L351.800889 471.438222a28.444444 28.444444 0 0 0-0.853333 43.349334l291.214222 257.479111a28.444444 28.444444 0 1 0 37.660444-42.666667L413.696 494.364444z" p-id="19664">
          </path>
          </svg>
          </button>`);
      },
      responsive: [
        {
          breakpoint: 992,
          settings: {
            dots: false,
            slidesToShow: 2,
            slidesToScroll: 2,
          },
        },
        {
          breakpoint: 767,
          settings: {
            dots: true,
            slidesToShow: 2,
            slidesToScroll: 2,
          },
        },
      ],
    });
    setTimeout(function () {
      $('{{ card_selector }}').slick('refresh');
      // resetHeight()
      $('.tab-content').css('opacity', '1');
    }, 100);
    // function resetHeight(){
    //   var items = $('{{ card_selector }} .item-card');
    //   var maxHeight = 0;
    //   items.each(function () {
    //     var currentHeight = $(this).outerHeight();
    //     if (currentHeight > maxHeight) {
    //       maxHeight = currentHeight;
    //     }
    //   });

    //   // 将所有 items 元素的高度设置为最大高度
    //   items.css('height', maxHeight + 'px');
    // }
  });
</script>
{% schema %}
{
  "name": "Index Best Sellers",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title"
    },
    {
      "type": "radio",
      "id": "title_style",
      "label": "Title Style",
      "options": [
        {
          "value": "1",
          "label": "Title Style1(叠影)"
        },
        {
          "value": "2",
          "label": "Title Style1(单色)"
        }
      ],
      "default": "1"
    },
    {
      "type": "text",
      "id": "title_add_desc",
      "label": "标题下方的描述"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "checkbox",
      "id": "enable_go_collection",
      "label": "Enable Go Collection?",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Index Best Sellers"
    }
  ]
}
{% endschema %}
