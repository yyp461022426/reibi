<style>
  /*  Header Top  */
  {% assign bg_header_top =  section.settings.bg_header_top %}
  {% assign text_header_top_color = section.settings.text_header_top_color %}
  {% assign top_message_font_size = section.settings.top_message_font_size %}

  /*  Search  */
  {% assign bg_search_color = section.settings.bg_search_color %}
  {% assign search_color = section.settings.search_color %}
  {% assign search_border_color = section.settings.search_border_color %}
  {% assign search_btn_color = section.settings.search_btn_color %}

  /*  Header Bottom  */
  {% assign max_height_logo_mb =  section.settings.max_height_logo_mb %}
  {% assign max_height_logo_pc =  section.settings.max_height_logo_pc %}

  {% assign bg_header_bottom_color = section.settings.bg_header_bottom_color %}
  {% assign header_bottom_link_color = section.settings.header_bottom_link_color %}
  {% assign header_bottom_icon_color = section.settings.header_bottom_icon_color %}
  {% assign header_bottom_padding_top = section.settings.header_bottom_padding_top %}
  {% assign header_bottom_padding_bottom = section.settings.header_bottom_padding_bottom %}

  /*  Cart  */
  {% assign bg_cart_color = section.settings.bg_cart_color %}
  {% assign cart_color = section.settings.cart_color %}
  {% assign cart_font_size = section.settings.cart_font_size %}

  {% assign logo_color = section.settings.logo_text_color %}

  .header-logo a.logo-title,
  .header-logo .logo-title svg {
    color: {{ logo_color }};
  }

  .header-top {
      background-color: {{ bg_header_top }};
      color: {{ text_header_top_color }};
      z-index: 99;
      position: relative;
  }

  .header-top a {
      color: {{ text_header_top_color }};
  }

  .header-top .close {
      margin-top: -2px;
  }

  .header-top .top-message {
      font-weight: 500;
      letter-spacing: 0;
      padding: 11px 25px 10px 25px;
      font-size: {{top_message_font_size}};
  }

  .header-top .top-message p a:hover {
      border-bottom-color: {{ text_header_top_color }};
  }

  .header-top .close:hover {
      color: {{ text_header_top_color }};
  }

  .text-center {
      text-align: center;
  }

  .logo-img {
      display: inline-block;
      position: relative;
  }

  /* mb和pc的判定存在问题，平移屏幕宽度会存在显示问题，暂时固定logo的宽度 */
  .logo-img img{
      width: {{ max_height_logo_pc }}
  }

  .header-mb .logo-img img,
  .logo-fixed .logo-img img,
  .header-mb .logo-title {
      width: {{ max_height_logo_mb }};
  }

  .header-pc .logo-img img {
      {% comment %} width: {{ max_height_logo_pc }}; {% endcomment %}
       width: unset;
       height: 32px;
  }

  .header-02 .search-form .input-group-field {
      color: {{ search_color }};
      background-color: {{ bg_search_color }};
      border-bottom-color: {{ search_border_color }};
  }
  .search-open .template-index .header-02 .search-form .input-group-field {
      color: {{ search_color }};
      background-color: {{ bg_search_color }};
      border-bottom-color: {{ search_border_color }};
  }

  .header-02 .search-form .search-bar ::-webkit-input-placeholder {
      color: {{ search_color }};
  }

  .header-02 .search-form .search-bar ::-moz-placeholder {
      color: {{ search_color }};
  }

  .header-02 .search-form .search-bar :-ms-input-placeholder {
      color: {{ search_color }};
  }

  .header-02 .search-form .search-bar :-moz-placeholder {
      color: {{ search_color }};
  }

  .cart-icon .cartCount {
      background-color: {{ bg_cart_color }};
      color: {{ cart_color }};
      font-size: {{cart_font_size}};
      font-weight: 400;
  }

  .header-bottom-right{
      display: flex;
      align-items: center;
      justify-content: flex-end;
  }

  .header-bottom-center .text-center{
      display: flex;
      align-items: center;
  }

  {% if settings.enable_recently_viewed_products %}
      .cart-icon.with-products .cart-badge,
      .cart-icon-sidebar.with-products .cart-badge {
          background-color: {{ bg_cart_color }} !important;
          color: {{ cart_color }} !important;
          font-size: {{cart_font_size}} !important;
          font-weight: 400
      }
  {% endif %}

  /* add form hcx */
  .search-links{
      cursor: pointer;
  }
  .turn-white{
    color: #FFFFFF;
  }
  .turn-white:hover{
    color: #FFFFFF;
    opacity: 0.9;
  }
  .cart-icon a{
    position: relative;
  }
  /* 公共样式 */
  .main-page-title {
      text-align: center;
      margin-top: 14px;
      margin-bottom: 24px;
      position: relative;
  }

  .main-page-title.with-desc{
      margin-bottom: 8px;
    }

  .main-page-title .small-title {
      font-size: 24px;
      z-index: 1;
      color: var(--text_color);
      font-weight: bold;
      position: relative;
  }

  {% comment %} .main-page-title .small-title::before {
    content: "";
    border-top: 4px solid #ffffff;
    position: absolute;
    width: 100%;
    top: 18px;
    left: 0;
    z-index: -1;
  }

  .main-page-title .small-title::after {
      content: "";
      border: 1px solid #6a6a6a;
      position: absolute;
      width: calc(100% + 26px);
      height: 20px;
      top: 20px;
      left: -13px;
      z-index: -2; 
  } {% endcomment %}

  .main-page-title .text-shadow {
      position: absolute;
      left: 0;
      right: 0;
      margin: auto;
      font-size: 36px;
      top: -12px;
      z-index: 0;
      font-weight: 700;
      color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
    background-image: linear-gradient(180deg, #c5ddff, transparent);
    white-space: nowrap;
    overflow: hidden;
  }

    .main-page-title .small-title2{
        line-height: 32px;
        font-size: 24px;
        color: #0D489D;
    }   

    .desc-add{
        text-align: center;
        font-size: 18px;
        color: var(--text_color);
        margin-bottom: 22px;
        padding: 0 90px;
        word-break: break-word;
    }

  .flex-center{
    display: flex;
    justify-content: center;
  }

  .flex-left{
    display: flex;
  }

  .product-id{
    display: none;
  }

  @media (min-width: 1200px) {
  }
  @media (max-width: 1199px) {
  }
  @media (max-width: 991px) {
  }
  @media (max-width: 767px) {
    .main-page-title {
        margin-bottom: 0;
    }
    .desc-add{
        padding: 0;
        margin-bottom: 12px;
    }
    .main-page-title .small-title2{
        line-height: 28px;
    }
    .main-page-title .small-title{
        font-size: 16px;
    }
    .main-page-title .text-shadow{
        font-size: 26px;
        top: -6px;
    }
    .main-page-title .small-title::after{
        height: 14px;
        top: 12px;
        z-index: -2;
    }
    .main-page-title .small-title::before{
        top: 10px;
    }

  }
  .nav-search-pop{
    width: unset;
      /* width: 100%;
      height: 100%;
      position: absolute;
      display: flex;
      justify-content: center;
      top: 30px;
      background: rgba(0, 0, 0, 0.5); */
  }
  /* add form hcx end */

  @media (max-width:1199px) {
      .search-open .wrapper-header .search-bar {
          background-color: {{ bg_search_color }};
      }
      .wrapper-navigation .header-bottom-right{
          border-top: 1px solid {{settings.border_color_menu_mb}};
          padding-top: 20px;
          margin-top: 15px;
      }
       .wrapper_header_02 .mb-area .wishlist .wishlist-quantity{
          display: inline-block;
          min-width: 23px;
          height: 23px;
          line-height: 23px;
          text-align: center;
          border-radius: 50%;
          background-color: {{ bg_cart_color }};
          color: {{ cart_color }};
          font-size: {{cart_font_size}};
          font-weight: 400;
          margin-left: 10px;
       }

      .cart-icon svg {
          width: 26px;
          height: 26px;
      }
  }

  @media (min-width:1200px) {
      .wrapper_header_02 .header-pc .icon-search svg,
      .wrapper_header_02 .customer-links svg,
      .wrapper_header_02 .wishlist svg,
      .wrapper_header_02 .header-pc .cart-icon svg {
          color: {{header_bottom_icon_color}}
      }

      .search-open .wrapper_header_02 .search-form .search-bar {
          /* background-color: {{ bg_search_color }}; */
      }

      .wrapper_header_02 .icon-search {
          color: {{ search_btn_color }};
      }

      .wrapper_header_02 .wishlist {
          position: relative;
          margin-right: 20px;
      }
      .wishlist-quantity {
          background: {{ section.settings.bg_wishlist_color }};
          color: {{ section.settings.wishlist_color }};
          font-size: {{cart_font_size}};
          font-weight: 400;
          line-height: 16px;
          height: 16px;
          width: 16px;
          top: -8px;
          right: -8px;
          -moz-border-radius: 50%;
          -webkit-border-radius: 50%;
          -ms-border-radius: 50%;
          -o-border-radius: 50%;
          border-radius: 50%;
          text-align: center;
          position: absolute;
      }

      .header-02 .header-bottom {
          background-color: {{ bg_header_bottom_color }};
          color: {{ header_bottom_link_color }};
      }

      .header-02 .lang-currency-groups, .header-02 .shipping-text {
          display: inline-block;
      }

      .header-02 .lang-currency-groups .dropdown-label {
          color: {{ header_bottom_link_color }};
      }

      .lang-currency-groups .btn-group .dropdown-item {
          color: var(--color_menu_level3);
      }

      .lang-currency-groups .btn-group .dropdown-item:hover,
      .lang-currency-groups .btn-group .dropdown-item:focus:
      .lang-currency-groups .btn-group .dropdown-item:active,
      .lang-currency-groups .btn-group .dropdown-item.active {
          color: {{ header_bottom_link_color }};
      }

      .lang-currency-groups .dropdown-menu {
          background-color: {{ bg_header_bottom_color }};
      }

      .search-open .wrapper_header_02 .search-form .close-search  {
          /* color: {{ search_color }}; */
          color: #FFFFFF;
      }
      .wrapper_header_02 .header-bottom {
          background-color: rgba(216, 216, 216, 0);
          padding-top: {{ header_bottom_padding_top }};
          padding-bottom: {{ header_bottom_padding_bottom }};
      }

      .header-lang-style2 .lang-currency-groups {
          margin-left: 0
      }
      .header-lang-style2 .lang-currency-groups .dropdown-toggle:after {
          color: {{ header_bottom_link_color }};
      }

      {% if section.settings.display_parallax %}
          .template-index .is-parallax {
              position: absolute;
              width: 100%;
              z-index: 3;
          }
          .template-index .header-bottom {
              background: transparent;
          }
          .header-bottom .wrapper-navigation .container{
            padding-left: 0;
            padding-right: 0;
          }
          .template-index .wrapper-navigation,
          .template-index .wrapper-navigation .main-menu {
              background-color: transparent;
          }

          .template-index .wrapper-navigation {
              display: none;
          }
          .template-index .is-parallax .wrapper-navigation {
              display: flex;
          }

          .template-index .header-02 .lang-currency-groups .dropdown-label,
          .template-index .header-lang-style2 .lang-currency-groups .dropdown-toggle:after {
              color: {{ section.settings.parallax_link_color }}
          }
          .template-index .header-02 .search-form .input-group-field {
              color: {{ section.settings.parallax_link_color }};
              border-color: {{ section.settings.parallax_link_color }};
              background-color: transparent;
          }
          .template-index .header-02 .search-form .input-group-field::placeholder {
              color: {{ section.settings.parallax_link_color }};
          }
          .search-open .header-02 .search-form .search-bar :-ms-input-placeholder {
              color: {{ search_color }};
          }
          .search-open .header-02 .search-form .search-bar ::-moz-placeholder {
              color: {{ search_color }};
          }

          .search-open .header-02 .search-form .search-bar ::-webkit-input-placeholder {
              color: {{ search_color }};
          }
          .template-index .wrapper_header_02 .header-pc .icon-search svg,
          .template-index .wrapper_header_02 .customer-links svg,
          .template-index .wrapper_header_02 .wishlist svg,
          .template-index .wrapper_header_02 .header-pc .cart-icon svg {
              color: {{ section.settings.parallax_link_color }};
          }
          .search-open .template-index .wrapper_header_02 .header-pc .icon-search svg {
              color: {{ search_btn_color }};
          }
          .template-index .sticky-wrapper:not(.is-sticky) .wrapper-navigation .site-nav .menu-lv-1 > a,
          .template-index .sticky-wrapper:not(.is-sticky) .wrapper-navigation .site-nav .menu-lv-1 > a:hover {
              color: {{ section.settings.parallax_link_color }};
          }
          .template-index .site-nav .menu-lv-1>a span:before {
              background-color: {{ section.settings.parallax_link_color }};
          }
          .template-index .wishlist-quantity {
              color: {{ section.settings.parallax_wishlist_color }};
              background: {{ section.settings.parallax_wishlist_bg }};
          }
          .template-index .header-pc .cart-icon .cartCount {
              color: {{ section.settings.parallax_wishlist_color }};
              background: {{ section.settings.parallax_wishlist_bg }};
          }
          .template-index .header-logo .has-paralax,
          .logo-parallax {
              display: none;
          }
          .template-index .logo-parallax {
              display: inline-block;
          }
      {% endif %}
  }
</style>
