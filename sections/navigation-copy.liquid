{% render 'style-navigation-copy' %}

<div class="wrapper-navigation" data-sticky-pc>
  {% comment %} {% if template != 'page.affiliate-test' and template != 'page.about-us-2' and settings.is_Christmas %}
    <img
      class="snow-on-nav"
      src="https://cdn.shopify.com/s/files/1/0632/4833/5096/files/snow_on_nav.png?v=1733995072"
      width=""
      height="100"
    >
  {% endif %} {% endcomment %}
  {% if section.settings.display_fixtop_menu and section.settings.logo_fix != blank %}
    <div class="header-logo logo-fixed">
      <a class="logo-img" href="{{ routes.cart_url | split: 'cart' | first }}" title="Logo">
        <img
          data-src="{{ section.settings.logo_fix | img_url: 'master' }}"
          src="{{ section.settings.logo_fix | img_url: 'master' }}"
          alt="{{ section.settings.logo_fix.alt | default: shop.name }}"
          itemprop="logo"
          class="lazyautosizes lazyloaded"
          data-sizes="auto"
        >
      </a>
    </div>
  {% endif %}

  <div class="main-menu jas-mb-style">
    <div class="container">
      <div class="row nav-bar-header">
        <div class="col-4">
          {% if shop.customer_accounts_enabled %}
            <div class="acc-mb svg-mb">
              <a href="{{ routes.account_url }}" title="User Icon" class="icon-user" data-user-mobile-toggle>
                {% if settings.header_layout == '05' %}
                  {% render 'icons8-male-user' %}
                {% elsif settings.header_layout == '06' %}
                  {% render 'icon-user-2' %}
                {% elsif settings.header_layout == '07' %}
                  {% render 'icons7-user' %}
                {% else %}
                  {% comment %}
                    <img
                      src="https://cdn.shopify.com/s/files/1/0632/4833/5096/files/user_1.1.png?v=1721966364"
                      width="21"
                      height="23"
                      alt="User"
                    >
                  {% endcomment %}
                  {% render 'icon-user-3' %}
                  {% comment %} {% render 'icon-user' %} {% endcomment %}
                {% endif %}
              </a>
              {%- render 'remind-login-pop' -%}
            </div>
          {% endif %}
        </div>
        <div class="col-4 search-header-logo">
          <div class="header-logo">
            {% if section.settings.logo_mb != blank %}
              <a class="logo-img" href="{{ routes.cart_url | split: 'cart' | first }}" title="Logo">
                <img
                  data-src="{{ section.settings.logo_mb | img_url: 'master' }}"
                  src="{{ section.settings.logo_mb | img_url: 'master' }}"
                  alt="{{ section.settings.logo_mb.alt | default: shop.name }}"
                  itemprop="logo"
                  class="lazyautosizes lazyloade"
                  data-sizes="auto"
                >
              </a>
            {% elsif section.settings.brand_text != '' %}
              <a class="logo-title" href="{{ routes.cart_url | split: 'cart' | first }}">
                {{ section.settings.brand_text }}
              </a>
            {% else %}
              <a class="logo-title" href="{{ routes.cart_url | split: 'cart' | first }}">
                {{ shop.name }}
              </a>
            {% endif %}
          </div>
        </div>
        <div class="col-4"></div>
      </div>
      <div class="row">
        <div class="col-12">
          <div class="mb-area">
            <nav class="nav-bar" role="navigation">
              {% render 'site-nav' %}
            </nav>
          </div>
        </div>
      </div>
      <div class="nav-search-part">
        <div class="halo-sidebar-wrapper custom-scrollbar">
          <div class="search-form" data-ajax-search>
            <div class="nav-side-search">
              <div class="header-search__form">
                <form action="{{ routes.search_url }}" method="get" class="search-bar" role="search">
                  <input type="hidden" name="type" value="product">
                  <input
                    type="search"
                    name="q"
                    {% if settings.enable_multilang %}
                      data-translate="general.search.placeholder" translate-item="placeholder"
                    {% endif %}
                    placeholder="{% if settings.layout_style == 'layout_style_surfup' %}{{ 'general.search.placeholder3' | t }}{% else %}{{ 'general.search.placeholder' | t }}{% endif %}"
                    class="input-group-field header-search__input"
                    aria-label="Search Site"
                    autocomplete="off"
                  >
                  <button type="submit" class="btn icon-search" aria-label="Search">
                    {% render 'icon-search' %}
                  </button>
                  {% if settings.header_style_mobile == 'header_mobile_3' %}
                    <a href="#" title="close" class="close close-search close-search-style-3" style="display: none;">
                      {% render 'icon-close' %}
                    </a>
                  {% endif %}
                </form>
              </div>

              <div class="quickSearchResultsWrap quickSearchResultsWrap_mb" style="display: none;">
                <div class="custom-scrollbar">
                  <div class="container">
                    <div class="header-block header-search__record">
                      <div class="box-title">
                        <span>History</span>
                        <span class="clear-record">
                          {% render 'icon-garbage' %}
                        </span>
                      </div>
                      <ul class="list-item"></ul>
                    </div>
                    {% if settings.enable_search_popular_products %}
                      <div class="header-block header-search__product">
                        <div class="box-title">
                          {% render 'multilang' with settings.popular_products_search_title %}
                        </div>

                        <div class="search__products">
                          <div
                            class="products-grid row line-dots"
                            data-loader-script="{{ 'halo.slide-custom.js' | asset_url }}"
                            slide-custom-init
                            data-arrow-enable="true"
                            data-mb-dots="true"
                            data-mb-slides-to-show="2"
                            data-breakpoint="1200"
                          >
                            {% for product in collections[settings.popular_products_collection].products
                              limit: settings.popular_products_limit
                            %}
                              <div class="grid-item">
                                {% if settings.layout_style == 'layout_style_1170' %}
                                  {% render 'product-grid-item-style-2' with product as product %}
                                {% elsif settings.layout_style == 'layout_style_fullwidth' %}
                                  {% render 'product-grid-item-style-3' with product as product %}
                                {% elsif settings.layout_style == 'layout_style_suppermarket' %}
                                  {% render 'product-grid-item-style-4' with product as product %}
                                {% else %}
                                  {% render 'sidebar-product-grid' with product as product %}
                                {% endif %}
                              </div>
                            {% endfor %}
                          </div>
                        </div>
                      </div>
                    {% endif %}

                    <div class="header-search__results-wrapper"></div>
                  </div>
                </div>
              </div>
            </div>

            {% capture search %}
                    {% raw %}{{#if is_loading}}{% endraw %}
                    <div class="header-search__results">
                        <div class="header-search__spinner-container">
                            <div class="loading-modal modal"><div></div><div></div><div></div><div></div></div>
                        </div>
                    </div>

                    {% raw %}{{else}}{% endraw %}

                    {% raw %}{{#if is_show}}{% endraw %}
                    <div class="header-search__results header-block">
                        {% raw %}
                        {{#if has_results}}
                        <div class="box-title">
                            {{ title_heading }}
                        </div>
                        <div class="search__products">
                            <div class="products-grid row">
                                {{#each results}}

                                <div class="grid-item col-6 col-sm-4 col{% endraw %}{{settings.popular_products_limit}} {% if settings.layout_style == 'layout_style_fullwidth' or settings.layout_style == 'layout_style_suppermarket' %}{% raw %} col-5{% endraw %}{% endif %}{% raw %}">
                                    <div class="inner product-item">
                                        <div class="inner-top">
                                            <div class="product-top">
                                                <div class="product-image">
                                                    <a href="{{url}}" class="product-grid-image">
                                                        <img src="{{image}}" alt="{{image_alt}}">                                               
                                                    </a>
                                                </div>
                                            </div>

                                            <div class="product-bottom">

                                                {% endraw %}{% if settings.show_vendor %}{% raw %}
                                                <div class="product-vendor">
                                                    {{vendor}}
                                                </div>
                                                {% endraw %}{% endif %}{% raw %}

                                                <a class="product-title" href="{{url}}">
                                                    {{title}}
                                                </a>

                                                <div class="price-box">
                                                    {{#if on_sale}}
                                                    <div class="price-sale">
                                                        <span class="old-price">{{ compare_at_price }}</span>
                                                        <span class="special-price">
                                                            {{ price }}
                                                        </span>
                                                    </div>
                                                    {{else}}
                                                    <div class="price-regular">
                                                        <span>{{ price }}</span>
                                                    </div>
                                                    {{/if}}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                {{/each}}
                            </div>              
                        </div>
                        
                        <div class="text-center">            
                            <a href="{{results_url}}" class="text-results header-search__see-more" data-results-count="{{results_count}}">
                                {{results_label}} ({{results_count}})
                            </a>
                        </div>
                        {{else}}

                        <p class="header-search__no-results text-results">{{ results_label }}</p>
                        {{/if}}
                        {% endraw %}
                    </div>
                    {% raw %}{{/if}}{% endraw %}
                    {% raw %}{{/if}}{% endraw %}
                {% endcapture %}

            <script id="search-results-template" type="text/template7">
              {
                {
                  search;
                }
              }
            </script>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% if section.settings.display_fixtop_menu %}
    <div class="fixed-right-menu">
      <div class="search-fixed">
        <a href="#" title="Search" class="icon-search" data-search-mobile-toggle>
          {% render 'icon-search' %}
        </a>
      </div>
      <div
        class="cart-fixed cart-icon"
        {% if settings.header_layout == '02_copy' or settings.header_layout == '02' or settings.header_layout == '03' %}
          data-cart-header-02
        {% endif %}
      >
        <a
          href="#"
          title="Cart"
          {% if settings.header_layout == '02_copy'
            or settings.header_layout == '02'
            or settings.header_layout == '03'
          %}
            data-cart-toggle
          {% endif %}
        >
          {% render 'icon-cart' %}
          <span class="cartCount" data-cart-count>
            {{ cart.item_count }}
          </span>
        </a>
      </div>
    </div>
  {% endif %}
</div>

<style>
  {% if settings.header_layout == '02' %}
      .site-nav .mega-menu .style_5 .skin-2 .azbrandstable .vendor-letter-menu a {
      	font-size: {{ section.settings.font_size_mnu_lv2 }}
      }
  {% endif %}
  @media (min-width:1200px) {
      {% unless section.settings.logo_fix != blank %}
      .header-lang-style2 .is-sticky .main-menu,
      .wrapper_header_default .is-sticky .main-menu {
          width: -moz-calc(100% - 112px);
          width: -webkit-calc(100% - 112px);
          width: -ms-calc(100% - 112px);
          width: calc(100% - 112px);
          margin-left: 112px;
      }
      {% endunless %}

      @-webkit-keyframes fadeInDown {
          from {
              opacity: 0;
              -webkit-transform: translate3d(0, -100%, 0);
              transform: translate3d(0, -100%, 0)
          }

          to {
              opacity: 1;
              -webkit-transform: translate3d(0, 0, 0);
              transform: translate3d(0, 0, 0)
          }
      }

      @keyframes fadeInDown {
          from {
              opacity: 0;
              -webkit-transform: translate3d(0, -100%, 0);
              transform: translate3d(0, -100%, 0)
          }

          to {
              opacity: 1;
              -webkit-transform: translate3d(0, 0, 0);
              transform: translate3d(0, 0, 0)
          }
      }

      @keyframes fadeOutUp {
          from {
              opacity: 1;
              -webkit-transform: translate3d(0, 0, 0);
              transform: translate3d(0, 0, 0)
          }

          to {
              opacity: 0;
              -webkit-transform: translate3d(0, -100%, 0);
              transform: translate3d(0, -100%, 0)
          }
      }

      .is-sticky .wrapper-navigation {
          animation-name: fadeInDown;
          animation-duration: 0.5s;
          animation-fill-mode: both
      }

      .sticky-wrapper.is-sticky .wrapper-navigation.sticky-hidden{
        animation-name: fadeOutUp;
        animation-duration: .5s;
        animation-fill-mode: both;
        transform: translate3d(0, -100%, 0);
        opacity: 0;
      }

      .site-nav .mega-menu .style_5 .mega-banner {
      	background-color: {{ section.settings.bg_style_new }};
      }
      .site-nav .mega-menu .style_5 .mega-banner .col-left:before {
      	background-color: {{ section.settings.bg_style_new }};
      }
      .site-nav .mega-menu .style_5 .mega-banner.skin-2:before {
      	background-color: {{ section.settings.bg_style_new }};
      }
      .site-nav .mega-menu .style_5 .mega-banner.skin-3.skin-3-product, .site-nav .mega-menu .style_5 .mega-banner.skin-3.skin-3-product:before, .site-nav .mega-menu .style_5 .mega-banner.skin-3.skin-3-product:after {
      	background-color: {{ section.settings.bg_style_new }} !important;
      }
      .site-nav .mega-menu .style_5 .mega-banner.skin-3 .col-product .slick-arrow {
      	background: {{ section.settings.bg_color_arrow }};
      	border: {{ section.settings.bg_color_arrow }};
      }
      .site-nav .mega-menu .style_5 .mega-banner.skin-3 .col-product .slick-arrow svg {
      	color: {{ section.settings.color_arrow }};
      }
  }
</style>

<script>
  window.fixtop_menu = {{ section.settings.display_fixtop_menu }};
</script>

