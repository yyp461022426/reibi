{% if section.blocks.size > 0 %}

{% case section.settings.brand_rows %}
    {% when '4' %}
        {%- assign grid_item_width = 'col-6 col-sm-6 col-md-4 col-lg-3' -%}

    {% when '5' %}
        {%- assign grid_item_width = 'col-6 col-sm-6 col-md-4 col-lg-3 col5' -%}

    {% when '6' %}
        {%- assign grid_item_width = 'col-6 col-sm-6 col-md-4 col-lg-3 col-xl-2' -%}
{% endcase %}

<section class="home-brands-block home-brands-style2" id="home-brands-{{section.id}}" data-loader-script="{{ 'halo.slide-brand-2.min.js' | asset_url }}">
    <div class="{% if section.settings.layout == 'default' %}container{% elsif section.settings.layout == 'padd_60' %}container-padd60{% endif %}">
        <div class="brands-block">
            {% if section.settings.brand_title != blank %}
            <div class="widget-title{% if section.settings.title_style == 'style_2' %} not-before{% elsif section.settings.title_style == 'style_3' %} style_3{% endif %}">
                <h3 class="box-title">
                    <span class="title">
                    {% render 'multilang' with section.settings.brand_title %}
                    </span>
                </h3>
                {% if settings.layout_home == 'layout_home_12' %}
                    {% if section.settings.view_all != blank %}
                        <a class="view_all" href="{{ section.settings.link_view_all }}" title="{{section.settings.view_all}}">
                            {% render 'multilang' with section.settings.view_all %}
                            <i class="fa fa-angle-right" aria-hidden="true"></i>
                        </a>
                    {% endif %}
                {% endif %}
                {% if section.settings.brand_des != blank %}
                <p>
                    {% render 'multilang' with section.settings.brand_des %}
                </p>
                {% endif %}
            </div>
            {% endif %}

            <div class="row brands-slider brands-style-2{% if section.settings.brand_item_style == 'style_2' %} item_style_2{% endif%}" data-brands-slider-style2 data-rows="{{ section.settings.brand_rows }}" data-brand-rows="{{ section.settings.show_brand_rows }}">
                {% for block in section.blocks %}
                <div class="item {{ grid_item_width }}{% if section.settings.brand_item_style == 'style_2' %} style_2{% endif%}">
                    {% if block.settings.image != blank %}
                    {%- assign preview_img = block.settings.image -%}
                    <a title="{{ block.settings.title }}" href="{{ block.settings.link }}" {% unless section.settings.brand_item_style == 'style_2' %}class="adaptive_height" style="padding-top: {{ 1 | divided_by: preview_img.aspect_ratio | times: 100 }}%"{% endunless %}>
                        <img data-src="{{ block.settings.image | img_url : '250x' }}" alt="{{ block.settings.image.alt | default: shop.name }}" {% render 'lazyload' %}/>
                        {% if section.settings.brand_item_style == 'style_2' %}
                            <span class="brand-name">{{ block.settings.title }}</span>
                        {% endif %}
                    </a>
                    {% else %}
                    <a title="{{ block.settings.title }}" href="{{ block.settings.link }}">
                        <div class="not_img">
                        210 x 70px
                        </div>
                    </a>
                    {% endif %}
                </div>
                {% endfor %}
            </div>

            {% unless settings.layout_home == 'layout_home_12' %}
                {% if section.settings.view_all != blank %}
                <a class="view_all" href="{{ section.settings.link_view_all }}" title="{{section.settings.view_all}}">
                    {% render 'multilang' with section.settings.view_all %}
                    <i class="fa fa-angle-right" aria-hidden="true"></i>
                </a>
                {% endif %}
            {% endunless %}
        </div>
    </div>
</section>

<style>
    {% assign margin_bottom =  section.settings.margin_bottom %}
    {% assign font_size_title = section.settings.font_size_title %}
    {% assign font_size_title_mb = section.settings.font_size_title_mb %}
    {% assign font_weight_title = section.settings.font_weight_title %}
    {% assign text_transform_title = section.settings.text_transform_title %}

    #home-brands-{{section.id}} .widget-title .box-title {
        {% if section.settings.color_title != 'rgba(0,0,0,0)' %}
            color: {{ section.settings.color_title }};
        {% endif %}
        {% if section.settings.font_size_title != blank %}
            font-size: {{ font_size_title }};
        {% endif %}
        font-weight: {{ font_weight_title }};
        text-transform: {{ text_transform_title }}
    }

    {% if section.settings.color_title != 'rgba(0,0,0,0)' %}
        .home-brands-block .brands-block .widget-title.style_3 {
            border-bottom-color: {{ section.settings.color_title }};
        }
    {% endif %}

    @media (max-width: 767px) {
        #home-brands-{{section.id}} {
            margin-bottom: {{ section.settings.margin_bottom_mb }}px;
        }
        {% if section.settings.font_size_title_mb != blank %}
            #home-brands-{{section.id}} .widget-title .box-title {
                font-size: {{ font_size_title_mb }}
            }
        {% endif %}
    }

    @media (min-width: 768px) and (max-width: 1199px) {
        #home-brands-{{section.id}} {
            margin-bottom: {{ section.settings.margin_bottom_tab }}px;
        }
    }

    @media (min-width: 1200px) {
        #home-brands-{{section.id}} {
        margin-bottom: {{ margin_bottom }}px;
        }
    }

</style>
{% endif %}


{% schema %}
    {
        "name": "Brands Block Style 2",
        "class": "home-brands-2-sections",
        "max_blocks": 10,
        "settings": [
            {
                "type": "select",
                "id": "layout",
                "label": "Layout:",
                "options": [
                    {
                        "value": "default",
                        "label": "Default"
                    },
                    {
                        "value": "padd_60",
                        "label": "Boxed"
                    }
                ],
                "default": "default"
            },
            {
                "type" : "text",
                "id" : "view_all",
                "label" : "Text view all"
            },
            {
                "type" : "url",
                "label" : "Link view all",
                "id" : "link_view_all"
            },
            {
                "type": "header",
                "content": "Margin Bottom:"
            },
            {
                "type": "range",
                "id": "margin_bottom_mb",
                "label": "Mobile",
                "min": 0,
                "max": 100,
                "step": 1,
                "default": 0
            },
            {
                "type": "range",
                "id": "margin_bottom_tab",
                "label": "Tablet",
                "min": 0,
                "max": 100,
                "step": 1,
                "default": 0
            },
            {
                "type": "range",
                "id": "margin_bottom",
                "label": "Desktop",
                "min": 0,
                "max": 100,
                "step": 1,
                "default": 0
            },
            {
                "type": "header",
                "content": "Header"
            },
            {
                "type": "text",
                "id": "brand_title",
                "label": "Title"
            },
            {
                "type" : "color",
                "id" : "color_title",
                "label" : "Title Color"
            },
            {
                "type" : "text",
                "id" : "font_size_title",
                "label" : "Title Font Size"
            },
            {
                "type" : "text",
                "id" : "font_size_title_mb",
                "label" : "Title Font Size Mobile"
            },
            {
                "type": "select",
                "id": "font_weight_title",
                "label": "Title Font Weight",
                "default": "700",
                "options": [
                {
                    "value": "400",
                    "label": "Regular"
                },
                {
                    "value": "500",
                    "label": "Medium"
                },
                {
                    "value": "600",
                    "label": "SemiBold"
                },
                {
                    "value": "700",
                    "label": "Bold"
                },
                {
                    "value": "900",
                    "label": "ExtraBold"
                }]
            },
            {
                "type": "select",
                "id": "text_transform_title",
                "label": "Title Text Transform",
                "options": [
                {
                    "value": "none",
                    "label": "None"
                },
                {
                    "value": "uppercase",
                    "label": "Uppercase"
                },
                {
                    "value": "capitalize",
                    "label": "Capitalize"
                },
                {
                    "value": "lowercase",
                    "label": "Lowercase"
                }],
                "default": "capitalize"
            },
            {
                "type": "select",
                "id": "title_style",
                "label": "Title Style:",

                "options": [
                    {
                        "value": "style_1",
                        "label": "Style 1"
                    },
                    {
                        "value": "style_2",
                        "label": "Style 2"
                    },
                    {
                        "value": "style_3",
                        "label": "Style 3"
                    }
                ],
                "default": "style_1"
            },
            {
                "type" : "textarea",
                "id" : "brand_des",
                "label" : "Description"
            },
            {
                "type": "select",
                "id": "brand_rows",
                "label": "Brand per row",
                "options": [
                    {
                        "value": "4",
                        "label": "4"
                    },
                    {
                        "value": "5",
                        "label": "5"
                    },
                    {
                        "value": "6",
                        "label": "6"
                    }
                ],
                "default": "5"
            },
            {
                "type": "select",
                "id": "show_brand_rows",
                "label": "Show Brands on",
                "options": [
                    {
                        "value": "1",
                        "label": "1 row"
                    },
                    {
                        "value": "2",
                        "label": "2 rows"
                    }
                ],
                "default": "2"
            },
            {
                "type": "header",
                "content": "Brand Item"
            },
            {
                "type": "select",
                "id": "brand_item_style",
                "label": "Style",
                "options": [
                    {
                        "value": "style_1",
                        "label": "Style 1"
                    },
                    {
                        "value": "style_2",
                        "label": "Style 2"
                    }
                ],
                "default": "style_1"
            }
        ],
        "blocks": [
            {
                "type": "image",
                "name": "Image",
                "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Image",
                    "info" : "Recommended Image: Width x Height (210 x 70)px"
                },
                {
                    "type": "text",
                    "id": "title",
                    "label": "Your Brands",
                    "default": "Loremous"
                },
                {
                    "type": "url",
                    "id": "link",
                    "label": "Link",
                    "info": "Optional"
                }
                ]
            }
        ],
        "presets": [
            {
                "name": "Brands Block Style 2",
                "category": "Brands"
            }
        ]
    }
{% endschema %}
