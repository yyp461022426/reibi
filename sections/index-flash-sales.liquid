<link
  rel="stylesheet"
  type="text/css"
  href="{{ 'index-flash-sales.css' | asset_url }}"
>
{%- assign render_slide = 'card-slide-show-' | append: section.id -%}
{%- assign card_selector = '.' | append: render_slide -%}
<div class="index-flash-sales index-normal-component">
  <div class="container">
    {% if section.settings.title and section.settings.title != '' %}
      <div class="show-mb">
        <h2 class="main-page-title {% if section.settings.title_add_desc %}with-desc{% endif %}">
          {% if section.settings.title_style == '1' %}
            <span class="small-title">{{ section.settings.title | upcase }}</span>
            <span class="text-shadow">{{ section.settings.title | upcase }}</span>
          {% else %}
            <span class="small-title2">{{ section.settings.title }}</span>
          {% endif %}
        </h2>
        {% if section.settings.title_add_desc %}
          <div class="desc-add">
            {{ section.settings.title_add_desc }}
          </div>
        {% endif %}
      </div>
    {% endif %}
    <div class="deals-box">
      <h2 class="deals-title">{{ section.settings.title | upcase }}</h2>
      <!-- 商品展示 -->
      <div class="products-show-box deals-box-mb">
        <div class="tab-content" style="opacity: 0;">
          <div class="index-normal-product-card {{ render_slide }} line-dots">
            {% for product in section.settings.collection.products limit: 8 %}
              {%- assign current_variant = product.selected_or_first_available_variant -%}
              <a class="product-item" href="{{ product.url | within: collection }}" loader-img-box>
                <div class="item-card">
                  <div class="info-box">
                    <div class="img-box">
                      <div class="img-pic">
                        {% if product.available == false %}
                          <strong class="sold-out">Sold Out</strong>
                        {% elsif current_variant.compare_at_price
                          and current_variant.compare_at_price != 0
                          and current_variant.available
                        %}
                          <div class="deals-on">
                            <strong class="deal-num">
                              -
                              {{-
                                current_variant.compare_at_price
                                | minus: current_variant.price
                                | times: 100.0
                                | divided_by: current_variant.compare_at_price
                                | round
                              -}}
                              %
                            </strong>
                            <strong class="deal-off"> OFF </strong>
                          </div>
                        {% endif %}
                        {% if product.metafields.custom.show_on_main_page %}
                          {{
                            product.metafields.custom.show_on_main_page
                            | image_url: width: 214, height: 214
                            | image_tag: class: 'pro-img'
                          }}
                        {% else %}
                          {{ product.images | last | image_url: width: 214, height: 214 | image_tag: class: 'pro-img' }}
                        {% endif %}
                      </div>
                    </div>
                    <div class="item-options">
                      <div class="pro-title">{{ product.title }}</div>
                      <div class="pro-price">
                        <div class="price">
                          {% if current_variant.compare_at_price and current_variant.compare_at_price != 0 %}
                            <div class="min-price">{{ current_variant.price | money }}</div>
                            <div class="max-price">{{ current_variant.compare_at_price | money }}</div>
                          {% else %}
                            <div class="normal-price">{{ current_variant.price | money }}</div>
                          {% endif %}
                        </div>
                      </div>
                      {% if product.metafields.custom.dimension %}
                        <div class="pro-param pro-size">
                          <span>{{ product.metafields.custom.dimension }}</span>
                        </div>
                      {% endif %}
                      {% if product.metafields.custom.load_capacity %}
                        <div class="pro-param pro-weight">
                          <span>{{ product.metafields.custom.load_capacity }}</span>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                  <div class="option-box">
                    <div class="purchase-btn" data-id="{{product.variants[0].id}}">Buy Now</div>
                    {% if product.available %}
                      {% render 'icon-cart-3' %}
                      {% comment %}
                        <img
                          src="https://cdn.shopify.com/s/files/1/0632/4833/5096/files/cart_1.1.png?v=1721966364"
                          width="24"
                          height="22"
                          class="add-to-cart"
                          data-id="{{product.variants[0].id}}"
                          alt="add to cart"
                        >
                      {% endcomment %}
                    {% else %}
                      <div class="sold-out-note">Sold Out</div>
                    {% endif %}
                  </div>
                </div>
              </a>
            {% endfor %}
          </div>
          {%- if section.settings.enable_go_collection -%}
            <div class="flex-center collection-link">
              <button
                class="custom-action-btn action-empty-btn"
                data-url="{{ section.settings.collection.url }}"
                custom-link-btn
              >
                MORE INFO
              </button>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>
