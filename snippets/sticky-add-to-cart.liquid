{%- assign current_variant = product.selected_or_first_available_variant -%}
<div class="sticky_form" data-sticky-add-to-cart product-price-calc>
  <div class="container container-regular">
    <div class="row align-items-center">
      {% if settings.display_countdown %}
        <div class="col-12 col-lg-3 content-left">
          <div class="sticky-countdown sticky-item">
            <div class="sticky_icon">
              <i class="fa fa-clock-o" aria-hidden="true"></i>
            </div>
            <div class="countdown-item" data-countdown-normal data-countdown-value=""></div>
          </div>
        </div>
      {% endif %}
      {% assign sticky_atc_layout = '2' %}
      {% if sticky_atc_layout == '1' %}
        <div
          class="no-js-hidden product-option has-default sticky-product-mobile"
          data-product="{{ product.id }}"
          data-section="{{ section.id }}"
          data-url="{{ product.url }}"
        >
          <div class="sticky-product-mobile-header">
            <a href="javascript:void(0)" class="sticky-product-close close" data-close-sticky-mobile>
              {% render 'icon-close' %}
            </a>
          </div>
          <div class="product sticky-product-mobile-content halo-productView-mobile">
            <div class="productView-thumbnail-wrapper is-hidden-desktop">
            </div>
            <div class="sticky-info">
              {%- if show_vendor -%}
                <h3 class="sticky-brand">
                  <span class="visually-hidden">{{ 'accessibility.vendor' | t }}</span>
                  {{ product.vendor | link_to_vendor }}
                </h3>
              {%- endif -%}
              <h4 class="sticky-title">
                {{ product.title | escape }}
              </h4>
              <div class="product-price total-price">
                <div class="total-discounted-money"></div>
                <div class="total-money">
                  {{ current_variant.price | money }}
                </div>
              </div>
              {% comment %} {%- if sticky_atc_layout == '1' -%}
                {% assign compare_price = current_variant.compare_at_price | money %}
                {% assign subtotal = current_variant.price | money %}
                 {% assign subtotal = current_variant.price | money %}
                <div class="sticky-price{% unless compare_price == subtotal %}{% if compare_price != blank %} has-compare-price{% endif %}{% endunless %}">
                  {% unless compare_price == subtotal %}
                    {% if compare_price != blank %}
                      <s class="money-compare-price" data-compare-price="{{ current_variant.compare_at_price }}">
                        {{- compare_price -}}
                      </s>
                    {% endif %}
                  {% endunless %}
                  <span class="money-subtotal">{{ subtotal }}</span>
                </div>
              {%- endif -%} {% endcomment %}
            </div>
            {% assign variantCount = product.variants | size %}
            {% render 'product-variant-sticky-mobile',
              block: block,
              product: product,
              variantCount: variantCount,
              current_variant: current_variant,
              picker_type: 'button'
            %}
          </div>
          <script type="application/json">
            {{ product.variants | json }}
          </script>
        </div>
      {% endif %}
      <div class="col-12{% if settings.display_countdown %} col-lg-9 content-right{% else %} col-lg-12{% endif %}">
        {% form 'product', product, id: 'form-sticky' %}
          <div class="{% unless settings.display_countdown %} no-countdown{% endunless %}">
            {% assign variant_count = product.variants | size %}
            <div class="row-variant-select-mb">
              <div class="col-variant">
                <div class="sticky-item sticky_group">
                  {% if variant_count > 1 and product.available %}
                    <div class="pr-selectors">
                      <a href="javascript:void(0)" class="pr-active" data-value="{{ product.variants[0].id }}">
                        {{ product.variants[0].title }} - {{ product.variants[0].price | money }}
                      </a>

                      <ul>
                        {% for variant in product.variants %}
                          {% assign value = variant.options[option_index] %}
                          <li>
                            <a
                              {% if variant.image != null %}
                                data-img="{{ variant.image.src | product_img_url: 'compact' }}"
                              {% else %}
                                data-img="{{ product.featured_image.src | product_img_url: 'compact' }}"
                              {% endif %}
                              data-value="{{ variant.id }}"
                              class="pr-swatch {% if variant.available == false %}sold-out{% endif %}"
                              {% if variant.available == false %}
                                disabled="disabled"
                              {% endif %}
                              href="javascript:void(0)"
                            >
                              {{ variant.title }} - {{ variant.price | money }}
                            </a>
                          </li>
                        {% endfor %}
                      </ul>
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
            <div class=" col-actions {% if variant_count == 1 and product.available %}center-mb{% endif %}">
              <div class=" col-img-title">
                <div class="pr-img sticky-item">
                  <img src="{{ product.featured_image.src  | product_img_url: 'compact' }}" alt="">
                  <div class="product-info">
                    <div class="product-title">
                      {% render 'multilang' with product.title %}
                    </div>

                    <div class="product-price total-price">
                      <div class="total-discounted-money"></div>
                      <div class="total-money">
                        {{ current_variant.price | money }}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              {% if product.available %}
                <div class="quantity">
                  <div class="qty-group">
                    <a href="#" data-minus-qtt class="minus button"></a>
                    <input type="text" data-qtt-id="quantity__{{ product.id }}" name="quantity" value="1">
                    <a href="#" data-plus-qtt class="plus button"></a>
                  </div>
                </div>
              {% endif %}
              <div class="row-variant-select-pc">
                <div class="col-variant">
                  <div class="sticky-item sticky_group">
                    {% if variant_count > 1 and product.available %}
                      <div class="pr-selectors">
                        <a href="javascript:void(0)" class="pr-active" data-value="{{ product.variants[0].id }}">
                          {{ product.variants[0].title }} - {{ product.variants[0].price | money }}
                        </a>

                        <ul>
                          {% for variant in product.variants %}
                            {% assign value = variant.options[option_index] %}
                            <li>
                              <a
                                {% if variant.image != null %}
                                  data-img="{{ variant.image.src | product_img_url: 'compact' }}"
                                {% else %}
                                  data-img="{{ product.featured_image.src | product_img_url: 'compact' }}"
                                {% endif %}
                                data-value="{{ variant.id }}"
                                class="pr-swatch {% if variant.available == false %}sold-out{% endif %}"
                                {% if variant.available == false %}
                                  disabled="disabled"
                                {% endif %}
                                href="javascript:void(0)"
                              >
                                {{ variant.title }} - {{ variant.price | money }}
                              </a>
                            </li>
                          {% endfor %}
                        </ul>
                      </div>
                    {% endif %}
                  </div>
                </div>
              </div>
              <div class="action sticky-item">
                {% if product.selected_or_first_available_variant.available %}
                  <input type="hidden" name="id" value="{{ product.variants[0].id }}">
                  <input
                    data-sticky-btn-addToCart
                    type="submit"
                    name="add"
                    class="btn sticky-add-to-cart"
                    {% if settings.enable_multilang %}
                      data-translate="products.product.add_to_cart"
                    {% endif %}
                    value="{{ 'products.product.add_to_cart' | t }}"
                  >
                {% else %}
                  <input
                    type="submit"
                    name="add"
                    class="btn sticky-add-to-cart"
                    {% if settings.enable_multilang %}
                      data-translate="products.product.unavailable"
                    {% endif %}
                    disabled
                    value="{{ 'products.product.unavailable' | t }}"
                  >
                {% endif %}
              </div>
            </div>
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</div>
<script>
  $(document).ready(function () {
    if (!$('.product-shop .countdown').length && !$('.product-shop .countdown-table').length) {
      $('[data-sticky-add-to-cart] .col-12.col-lg-3').remove();
    }
  });
</script>
