{%- liquid
  assign on_sale = false
  if badge_detail
    assign current_variant = product.selected_or_first_available_variant
    if current_variant.compare_at_price > current_variant.price
      assign on_sale = true
    endif
  else
    if product.compare_at_price_min > product.price_min
      assign on_sale = true
    endif
  endif

  assign sold_out = true
  if product.available
    assign sold_out = false
  endif

  assign custom_label = false
  assign new_label = false

  for tag in product.tags
    assign tag_handle = tag | handle
    if tag_handle == 'label'
      assign custom_label = true
    endif

    if tag_handle == 'new'
      assign new_label = true
    endif
  endfor

  assign bundle_label = false
  if product.metafields.c_f.grouped_sub_product and settings.enable_label_bundle
    assign bundle_label = true
  endif

  assign date_published = product.published_at | date: '%s'
  assign date_now = 'now' | date: '%s'
  assign date_minus = date_now | minus: date_published
  assign date_difference = date_minus | divided_by: 86400
-%}
{% assign current_variant = product.selected_or_first_available_variant %}
{% if settings.style_product_grid == 'style_product_grid_3' or settings.style_product_grid == 'style_product_grid_6' %}
  {% if on_sale
    or sold_out
    or custom_label
    or bundle_label
    or new_label
    or date_difference < settings.time_show_badgeNew
    or current_variant.metafields.custom.presale_info.value.isPresale
    or current_variant.metafields.custom.is_flash_sale.value
    or product.metafields.custom.custom_tag_show.value.show_custom_tag
  %}
    <div class="product-label" data-label-new-number="{{settings.product_show_badgeNew}}">
      {%- if product.metafields.custom.custom_tag_show.value.show_custom_tag -%}
        {%- assign tag_arr = product.metafields.custom.custom_tag_show.value.tag_arr -%}
        {%- for item in tag_arr -%}
          <strong
            class="label flash-sale-label"
            style="background-color: {{item.background_color}};color: {{ item.color }};"
            {% if settings.enable_multilang %}
              data-translate="products.product.custom_label"
            {% endif %}
          >
            {{ item.tag_content }}
          </strong>
        {%- endfor -%}
      {%- elsif current_variant.metafields.custom.is_flash_sale -%}
        <strong
          class="label flash-sale-label"
          {% if settings.enable_multilang %}
            data-translate="products.product.custom_label"
          {% endif %}
        >
          Flash Sales Today
        </strong>
      {%- endif -%}

      {% if new_label %}
        <strong
          class="label new-label"
          {% if settings.enable_multilang %}
            data-translate="products.product.new_label"
          {% endif %}
        >
          {{ 'products.product.new_label' | t }}
        </strong>
        {% if settings.layout_style == 'layout_style_surfup'
          or settings.layout_home == 'layout_home_7'
          or settings.layout_home == 'layout_home_18'
          or settings.layout_home == 'layout_home_14'
        -%}
        {% endif %}
      {% elsif date_difference < settings.time_show_badgeNew %}
        {% if serial <= settings.product_show_badgeNew %}
          {% if settings.enable_label_new %}
            <strong
              class="label new-label"
              {% if settings.enable_multilang %}
                data-translate="products.product.new_label"
              {% endif %}
            >
              {{ 'products.product.new_label' | t }}
            </strong>
            {% if settings.layout_style == 'layout_style_surfup'
              or settings.layout_home == 'layout_home_7'
              or settings.layout_home == 'layout_home_18'
              or settings.layout_home == 'layout_home_14'
            -%}
            {% endif %}
          {% endif %}
        {% endif %}
      {% endif %}

      {% if on_sale %}
        {% if settings.type_label_sale == 'label_sale' %}
          <strong
            class="label sale-label"
            {% if settings.enable_multilang %}
              data-translate="products.product.sale"
            {% endif %}
          >
            {{ 'products.product.sale' | t }}
          </strong>
          {% if settings.layout_style == 'layout_style_surfup'
            or settings.layout_home == 'layout_home_7'
            or settings.layout_home == 'layout_home_18'
            or settings.layout_home == 'layout_home_14'
          -%}
          {% endif %}
        {% else %}
          {% if badge_detail %}
            <strong class="label sale-label">
              -
              {{-
                current_variant.compare_at_price
                | minus: current_variant.price
                | times: 100.0
                | divided_by: current_variant.compare_at_price
                | round
              -}}
              %
            </strong>
            {% if settings.layout_style == 'layout_style_surfup'
              or settings.layout_home == 'layout_home_7'
              or settings.layout_home == 'layout_home_18'
              or settings.layout_home == 'layout_home_14'
            -%}
            {% endif %}
          {% else %}
            {% liquid
              assign list_compare = product.variants | where: 'compare_at_price'
              assign compare = 0
              for variant in list_compare
                assign saving = variant.compare_at_price | minus: variant.price | times: 100.0 | divided_by: variant.compare_at_price | round
                if saving > compare
                  assign compare = saving
                endif
              endfor
              if compare < 1
                assign compare = product.compare_at_price_min | minus: product.price_min | times: 100.0 | divided_by: product.compare_at_price_min | round
              endif
            %}
            <strong class="label sale-label"> -{{ compare }}% </strong>
            {% if settings.layout_style == 'layout_style_surfup'
              or settings.layout_home == 'layout_home_7'
              or settings.layout_home == 'layout_home_18'
              or settings.layout_home == 'layout_home_14'
            -%}
            {% endif %}
          {% endif %}
        {% endif %}
      {% endif %}

      {% if sold_out %}
        <strong
          class="label sold-out-label"
          {% if settings.enable_multilang %}
            data-translate="products.product.sold_out"
          {% endif %}
        >
          {{ 'products.product.sold_out' | t }}
        </strong>
        {% if settings.layout_style == 'layout_style_surfup'
          or settings.layout_home == 'layout_home_7'
          or settings.layout_home == 'layout_home_18'
          or settings.layout_home == 'layout_home_14'
        -%}
        {% endif %}
      {% endif %}

      {% if current_variant.metafields.custom.presale_info.value.isPresale %}
        <strong
          class="label presale-label"
          {% if settings.enable_multilang %}
            data-translate="products.product.custom_label"
          {% endif %}
        >
          Presale
        </strong>
      {% endif %}

      {% if custom_label %}
        <strong
          class="label custom-label"
          {% if settings.enable_multilang %}
            data-translate="products.product.custom_label"
          {% endif %}
        >
          {{ 'products.product.custom_label' | t }}
        </strong>
        {% if settings.layout_style == 'layout_style_surfup'
          or settings.layout_home == 'layout_home_7'
          or settings.layout_home == 'layout_home_18'
          or settings.layout_home == 'layout_home_14'
        -%}
        {% endif %}
      {% endif %}

      {% if bundle_label %}
        <strong
          class="label bundle-label"
          {% if settings.enable_multilang %}
            data-translate="products.product.custom_label"
          {% endif %}
        >
          {{ 'products.product.bundle_label' | t }}
        </strong>
      {% endif %}
    </div>
  {% endif %}
{% else %}
  {% if on_sale
    or sold_out
    or custom_label
    or bundle_label
    or new_label
    or date_difference < settings.time_show_badgeNew
    or current_variant.metafields.custom.presale_info.value.isPresale
    or current_variant.metafields.custom.is_flash_sale.value
    or product.metafields.custom.custom_tag_show.value.show_custom_tag
  %}
    <div class="product-label" data-label-new-number="{{settings.product_show_badgeNew}}">
      {%- if product.metafields.custom.custom_tag_show.value.show_custom_tag -%}
        {%- assign tag_arr = product.metafields.custom.custom_tag_show.value.tag_arr -%}
        {%- for item in tag_arr -%}
          <strong
            class="label flash-sale-label"
            style="background-color: {{item.background_color}};color: {{ item.color }};"
            {% if settings.enable_multilang %}
              data-translate="products.product.custom_label"
            {% endif %}
          >
            {{ item.tag_content }}
          </strong>
        {%- endfor -%}
      {%- elsif current_variant.metafields.custom.is_flash_sale -%}
        <strong
          class="label flash-sale-label"
          {% if settings.enable_multilang %}
            data-translate="products.product.custom_label"
          {% endif %}
        >
          Flash Sales Today
        </strong>
      {%- endif -%}

      {% if on_sale %}
        {% if settings.type_label_sale == 'label_sale' %}
          <strong
            class="label sale-label"
            {% if settings.enable_multilang %}
              data-translate="products.product.sale"
            {% endif %}
          >
            {{ 'products.product.sale' | t }}
          </strong>
        {% else %}
          {% if badge_detail %}
            <strong class="label sale-label">
              -
              {{-
                current_variant.compare_at_price
                | minus: current_variant.price
                | times: 100.0
                | divided_by: current_variant.compare_at_price
                | round
              -}}
              %
            </strong>
          {% else %}
            {% liquid
              assign list_compare = product.variants | where: 'compare_at_price'
              assign compare = 0
              for variant in list_compare
                assign saving = variant.compare_at_price | minus: variant.price | times: 100.0 | divided_by: variant.compare_at_price | round
                if saving > compare
                  assign compare = saving
                endif
              endfor
              if compare < 1
                assign compare = product.compare_at_price_min | minus: product.price_min | times: 100.0 | divided_by: product.compare_at_price_min | round
              endif
            %}
            <strong class="label sale-label"> -{{ compare }}% </strong>
          {% endif %}
        {% endif %}
      {% endif %}

      {% if sold_out %}
        <strong
          class="label sold-out-label"
          {% if settings.enable_multilang %}
            data-translate="products.product.sold_out"
          {% endif %}
        >
          {{ 'products.product.sold_out' | t }}
        </strong>
      {% endif %}

      {% if new_label %}
        <strong
          class="label new-label"
          {% if settings.enable_multilang %}
            data-translate="products.product.new_label"
          {% endif %}
        >
          {{ 'products.product.new_label' | t }}
        </strong>
      {% elsif date_difference < settings.time_show_badgeNew %}
        {% if serial <= settings.product_show_badgeNew %}
          {% if settings.enable_label_new %}
            <strong
              class="label new-label"
              {% if settings.enable_multilang %}
                data-translate="products.product.new_label"
              {% endif %}
            >
              {{ 'products.product.new_label' | t }}
            </strong>
          {% endif %}
        {% endif %}
      {% endif %}

      {% if custom_label %}
        <strong
          class="label custom-label"
          {% if settings.enable_multilang %}
            data-translate="products.product.custom_label"
          {% endif %}
        >
          {{ 'products.product.custom_label' | t }}
        </strong>
      {% endif %}
      {% assign current_variant = product.selected_or_first_available_variant %}
      {% if current_variant.metafields.custom.presale_info.value.isPresale %}
        <strong
          class="label presale-label"
          {% if settings.enable_multilang %}
            data-translate="products.product.custom_label"
          {% endif %}
        >
          Presale
        </strong>
      {% endif %}

      {% if bundle_label %}
        <strong
          class="label bundle-label"
          {% if settings.enable_multilang %}
            data-translate="products.product.custom_label"
          {% endif %}
        >
          {{ 'products.product.bundle_label' | t }}
        </strong>
      {% endif %}
    </div>
  {% endif %}
{% endif %}
