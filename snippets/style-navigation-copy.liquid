<style>
  {% assign bg_menu =  section.settings.bg_menu %}
  {% assign bg_dropdown_menu = section.settings.bg_dropdown_menu %}
  {% assign nav_height = '60px' %}

  {% assign alignment_nav =  section.settings.alignment %}


  /*  Menu Lv 1  */
  {% assign color_menu_lv1 = section.settings.color_menu_lv1 %}
  {% assign hover_color_mnu_lv1 = section.settings.hover_color_mnu_lv1 %}
  {% assign font_size_mnu_lv1 = section.settings.font_size_mnu_lv1 %}
  {% assign font_weight_mnu_lv1 = section.settings.font_weight_mnu_lv1 %}
  {% assign text_transform_mnu_lv1 = section.settings.text_transform_mnu_lv1 %}
  {% assign letter_spacing_mnu_lv1 = section.settings.letter_spacing_mnu_lv1 %}

  /*  Menu Lv 2  */
  {% assign color_menu_lv2 = section.settings.color_menu_lv2 %}
  {% assign hover_color_mnu_lv2 = section.settings.hover_color_mnu_lv2 %}
  {% assign font_size_mnu_lv2 = section.settings.font_size_mnu_lv2 %}
  {% assign font_weight_mnu_lv2 = section.settings.font_weight_mnu_lv2 %}
  {% assign text_transform_mnu_lv2 = section.settings.text_transform_mnu_lv2 %}
  {% assign letter_spacing_mnu_lv2 = section.settings.letter_spacing_mnu_lv2 %}

  /*  Menu Lv 3  */
  {% assign color_menu_lv3 = section.settings.color_menu_lv3 %}
  {% assign hover_color_mnu_lv3 = section.settings.hover_color_mnu_lv3 %}
  {% assign font_size_mnu_lv3 = section.settings.font_size_mnu_lv3 %}
  {% assign font_weight_mnu_lv3 = section.settings.font_weight_mnu_lv3 %}
  {% assign text_transform_mnu_lv3 = section.settings.text_transform_mnu_lv3 %}
  {% assign letter_spacing_mnu_lv3 = section.settings.letter_spacing_mnu_lv3 %}

  /*  Label - Navigation  */
  {% assign bg_lb_sale = section.settings.bg_lb_sale %}
  {% assign color_lb_sale = section.settings.color_lb_sale %}
  {% assign bg_lb_new = section.settings.bg_lb_new %}
  {% assign color_lb_new = section.settings.color_lb_new %}
  {% assign bg_lb_hot = section.settings.bg_lb_hot %}
  {% assign color_lb_hot = section.settings.color_lb_hot %}

  .nav-vertical .social-icons a {
      color: {{ color_menu_lv1 }};
  }

  .nav-vertical .header-logo img {
      width: {{ section.settings.max_height_logo_pc }};
  }



  .site-nav .menu-lv-1 > a,
  .site-nav .menu-mb-title {
      font-size: {{ font_size_mnu_lv1 }};
      font-weight: {{ font_weight_mnu_lv1 }};
      text-transform: {{ text_transform_mnu_lv1 }};
      letter-spacing: {{ letter_spacing_mnu_lv1 }};
  }

  .site-nav .mega-menu .menu-lv-2 > a,
  .site-nav .mega-menu .mega-banner .title {
      font-size: {{ font_size_mnu_lv2 }};
      font-weight: {{ font_weight_mnu_lv2 }};
      text-transform: {{ text_transform_mnu_lv2 }};
      letter-spacing: {{ letter_spacing_mnu_lv2 }};
  }

  .site-nav .menu-lv-3 > a,
  .site-nav .no-mega-menu .menu-lv-2 > a {
      font-size: {{ font_size_mnu_lv3 }};
      font-weight: {{ font_weight_mnu_lv3 }};
      text-transform: {{ text_transform_mnu_lv3 }};
      letter-spacing: {{ letter_spacing_mnu_lv3 }};
  }

  @media (min-width:1200px) {
      .wrapper-navigation .main-menu {
          {% comment %} {% if settings.is_Christmas %}
            background-color: var(--Christmas_green_color);
          {%  else %} {% endcomment %}
            {% comment %} background-color: var(--color_base); {% endcomment %}
            background-color: #ffffff;
          {% comment %} {% endif %} {% endcomment %}
      }

      .transp-nav .wrapper-navigation .main-menu {
          background: rgba(255, 255, 255, 0);
      }

      {% unless settings.layout_style == 'layout_style_fullwidth' %}
      .wrapper_header_06.header-lang-style2 .is-sticky .fixed-right-menu .cart-fixed .cartCount {
          background-color: {{ color_menu_lv1 }};
          color: {{ bg_menu }};
      }
      {% endunless%}
      .navigation-vertical-menu,
      .wrapper-navigation,
      .main-menu,
      .vertical-menu .nav-bar {
          /* background-color: {{ bg_menu }}; */
          background-color: rgba(255, 255, 255, 0);
          height: {{ nav_height }};
      }

      .header-02 .is-sticky .wrapper-navigation,
      .header-02 .is-sticky .main-menu {
          background-color: {{ bg_menu }};
      }

      .navigation-08 .site-nav .mega-menu .sub-menu-mobile {
          background-color: {{ section.settings.bg_style_new_top }};
      }

      .site-nav .sub-menu-mobile,
      .site-nav .sub-menu-mobile .bg {
          background-color: {{ bg_dropdown_menu }};
      }

      .wrapper-navigation .main-menu {
          text-align: {{ alignment_nav }};
          display: flex;
          align-items: center;
          /* background: #0d489d; */
      }

      .site-nav{
          display: flex;
      }

      .site-nav .menu-lv-1 .icon-label{
          top: -28px;
          right: 0px;
      }
      .site-nav .no-mega-menu:hover>.sub-menu-mobile{
          transform: translateY(30px);
          top: {{ nav_height | minus:30 |  append: 'px' }};
      }
      .is-sticky .site-nav .no-mega-menu:hover>.sub-menu-mobile{
          top: 30px;
      }
      .site-nav .menu-lv-1{
          width: 100%;
          display: flex;
          align-items: center;
          justify-content: center;
          margin: unset;
          /* position: relative; */
      }

      .site-nav .nav-hot-item{
          {% comment %} background-image: url("https://cdn.shopify.com/s/files/1/0632/4833/5096/files/nav_hot_bg.png?v=1730689571"); {% endcomment %}
          background-size: 100% 100%;
          background-repeat: no-repeat;
      }

      .site-nav .menu-lv-1:hover{
          {% comment %} {% if settings.is_Christmas %}
            background-color: var(--Christmas_red_color);
          {%  else %} {% endcomment %}
            background-color: unset;
            {% comment %} background-color: var(--color_base_sec); {% endcomment %}
          {% comment %} {% endif %} {% endcomment %}
          transition: all .3s;
      }

      .site-nav .menu-lv-1:hover .nav-inner-box >span{
        color: var(--color_base);
      }

      .site-nav .menu-lv-1:hover>a>span:not(.icon-dropdown):before {
          width: 100%;
          visibility: hidden;
      }

      /*  Menu Lv 1  */
      .wrapper_header_supermarket .vertical-menu .menu-lv-1.dropdown>a:after {
          color: {{ color_menu_lv1 }};
          width: 100%;
          line-height: {{ nav_height }};
          text-align: center;
      }


      .has_sticky .wrapper_header_default .wrapper-top-cart .cart-icon svg,
      .wrapper-navigation .fixed-right-menu a,
      .wrapper-navigation .site-nav .menu-lv-1 > a,
      .wrapper_header_supermarket .vertical-menu .menu-lv-1.dropdown>a:after {
          /* color: {{ color_menu_lv1 }}; */
          color: var(--body_color);
          /* width: 100%; */
          /* line-height: {{ nav_height }}; */
          text-align: center;
          font-size: 16px;
      }

      .has_sticky .wrapper-navigation .site-nav .menu-lv-1 > a{
          height: 100%;
          display: flex;
          align-items: center;
      }

      .is-sticky .wrapper-navigation{
          {% comment %} {% if settings.is_Christmas %}
            background-color: var(--Christmas_green_color);
          {%  else %} {% endcomment %}
            {% comment %} background-color: var(--color_base); {% endcomment %}
            background-color: #ffffff;
          {% comment %} {% endif %} {% endcomment %}
      }

      .nav-inner-box{
          display: inline;
          position: relative;
      }

      .site-nav-dropdown span{
          font-size: 14px;
      }

      {% unless settings.header_layout == 'vertical' %}
      .is-sticky .wrapper-navigation .fixed-right-menu .search-fixed,
      .is-sticky .wrapper-navigation .fixed-right-menu .cart-fixed {
          border: unset;
          /* border-left-color: {{ section.settings.color_menu_lv1 | color_modify: 'alpha', 0.15 }}; */
      }

      {% else %}
      .navigation-vertical-menu .mb-area .nav-bar {
          max-height: -moz-calc(100vh - 78px - 115px - 77px - 77px - 100px);
          max-height: -webkit-calc(100vh - 78px - 115px - 77px - 77px - 100px);
          max-height: -ms-calc(100vh - 78px - 115px - 77px - 77px - 100px);
          max-height: calc(100vh - 78px - 115px - 77px - 77px - 100px);
          max-height: calc(100vh - 45px - {{ section.settings.max_height_logo_pc }} - 115px - 77px - 77px - 100px);
      }

      .site-nav .no-mega-menu >.sub-menu-mobile {
          background-color: rgba(255, 255, 255, 0);
      }

      .site-nav .no-mega-menu >.sub-menu-mobile > .site-nav-dropdown {
          background-color: {{ bg_dropdown_menu }};
      }
      {% endunless %}

      .site-nav .menu-lv-1 > a:hover {
          color: {{ hover_color_mnu_lv1 }};
      }

      .site-nav .menu-lv-1>a span:before {
          background-color: {{ hover_color_mnu_lv1 }};
      }

      /*  Menu Lv 2  */
      .site-nav .menu-lv-2>a,
      .site-nav .mega-menu .mega-banner .title,
      .site-nav .mega-menu .product-item .btn {
          color: {{ color_menu_lv2 }};
      }

      .site-nav .mega-menu .product-item .btn {
          border-bottom-color: {{ section.settings.color_menu_lv2 | color_modify: 'alpha', 0.7 }};
      }

      .site-nav .menu-lv-2 > a:hover {
          color: {{ hover_color_mnu_lv2 }};
      }

      .navigation-08 .site-nav .no-mega-menu li > a span:before, .navigation-08 .site-nav .no-mega-menu .dropdown > a span:before {
          background-color: {{ hover_color_mnu_lv3 }};
      }

      .navigation-08 .site-nav .no-mega-menu li:hover, .navigation-08 .site-nav .no-mega-menu .dropdown:hover {
          background-color: {{ section.settings.bg_dropdown_menu_item }}
      }

      /*  Menu Lv 3  */
      .site-nav .menu-lv-3 > a,
      .site-nav .no-mega-menu .menu-lv-2 > a{
          color: {{ color_menu_lv3 }};
      }

      .site-nav .menu-lv-3 > a:hover,
      .site-nav .no-mega-menu .menu-lv-2 > a:hover {
          color: {{ hover_color_mnu_lv3 }};
      }

      .site-nav .menu-lv-3 > a span:before {
          background-color: {{ hover_color_mnu_lv3 }};
      }

      .site-nav .icon_sale:before {
          border-top-color: {{ bg_lb_sale }};
      }

      .site-nav .icon_new:before {
          border-top-color: {{ bg_lb_new }};
      }

      .site-nav .icon_hot:before {
          border-top-color: {{ bg_lb_hot }};
      }
  }

  .site-nav .icon_sale {
      background-color: {{ bg_lb_sale }};
      color: {{ color_lb_sale }};
  }

  .site-nav .icon_new {
      background-color: {{ bg_lb_new }};
      color: {{ color_lb_new }};
  }

  .site-nav .icon_hot {
      background-color: {{ bg_lb_hot }};
      color: {{ color_lb_hot }};
  }

  .site-nav .mega-menu .style_5 .skin-2 .azbrandstable .vendor-letter-menu a, .site-nav .mega-menu .style_5 .mega-banner.skin-2 .col-right .link-brands {
      color: {{ color_menu_lv2 }};
  }
  {% if settings.layout_home == 'layout_home_12'%}
      .layout_default .site-nav .mega-menu .style_5 .skin-2 .azbrandstable .vendor-letter-menu a {
          font-size: {{ font_size_mnu_lv2 }};
      }
      .layout_default .site-nav .mega-menu .style_5 .mega-banner.skin-2 .col-right .link-brands {
          color: {{ hover_color_mnu_lv3 }};
          text-decoration-color: {{ hover_color_mnu_lv3 | color_modify: 'alpha', 0.3 }};
      }
  {% endif %}

  @media (max-width:1199px) {
      .site-nav .icon_sale:before {
          border-right-color: {{ bg_lb_sale }};
      }

      .site-nav .icon_new:before {
          border-right-color: {{ bg_lb_new }};
      }

      .site-nav .icon_hot:before {
          border-right-color: {{ bg_lb_hot }};
      }
  }
</style>
