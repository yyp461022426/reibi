<link rel="stylesheet" type="text/css" href="{{ 'index-other-series.css' | asset_url }}">
<div class="index-other-series">
  <div class="container">
    {% if section.settings.title and section.settings.title != '' %}
      <h2 class="main-page-title">
        <span class="small-title">{{ section.settings.title | upcase }}</span>
        <span class="text-shadow">{{ section.settings.title | upcase }}</span>
      </h2>
    {% endif %}
    <div class="series-box">
      {% for block in section.blocks limit: 6 %}
        <div class="series-item">
          <div class="img-box">
            <a href="{{ block.settings.link }}">
              {{ block.settings.series_img | image_url: width: 380 | image_tag: class: 'series-img' }}
              <div class="link-btn">{{ block.settings.btn_words }}</div>
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Index Other Series",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title"
    }
  ],
  "blocks": [
    {
      "name": "Every block",
      "type": "card-show",
      "settings": [
        {
          "type": "image_picker",
          "id": "series_img",
          "label": "Series Image"
        },
        {
          "type": "text",
          "id": "btn_words",
          "label": "Btn words"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection Link of This Series"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Index Other Series"
    }
  ]
}
{% endschema %}
